---
---

<footer class="border-t border-[#1E293B] bg-[#0B0F1A] px-4 sm:px-6 py-8 sm:py-12">
  <div class="mx-auto max-w-5xl">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <div class="mb-3 flex items-center gap-2 text-lg font-bold">
          <img src="/images/pulse-logo.png" alt="Cerebrus Pulse" class="h-8 w-8 object-contain" />
          <span class="text-[#E8ECF4]">Cerebrus <span class="gradient-text">Pulse</span></span>
        </div>
        <p class="text-sm text-[#94A3B8]">
          Real-time crypto intelligence via <span class="text-[#60A5FA]">x402</span>, <span class="text-[#FF69B4]">A2A</span>, and <span class="text-[#FBBF24]">ACP</span>.
        </p>
      </div>

      <div>
        <h4 class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#64748B]">Documentation</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/quickstart" class="text-[#94A3B8] hover:text-[#60A5FA] underline underline-offset-2 decoration-transparent hover:decoration-[#60A5FA] transition-all duration-200">Quickstart</a></li>
          <li><a href="/api/pulse" class="text-[#94A3B8] hover:text-[#60A5FA] underline underline-offset-2 decoration-transparent hover:decoration-[#60A5FA] transition-all duration-200">API Reference</a></li>
          <li><a href="/guides/x402-payments" class="text-[#94A3B8] hover:text-[#60A5FA] underline underline-offset-2 decoration-transparent hover:decoration-[#60A5FA] transition-all duration-200">x402 Payments</a></li>
          <li><a href="/guides/a2a-agents" class="text-[#94A3B8] hover:text-[#FF69B4] underline underline-offset-2 decoration-transparent hover:decoration-[#FF69B4] transition-all duration-200">A2A Protocol</a></li>
          <li><a href="/guides/acp-agents" class="text-[#94A3B8] hover:text-[#FBBF24] underline underline-offset-2 decoration-transparent hover:decoration-[#FBBF24] transition-all duration-200">ACP for Agents</a></li>
          <li><a href="/reference/response-schemas" class="text-[#94A3B8] hover:text-[#60A5FA] underline underline-offset-2 decoration-transparent hover:decoration-[#60A5FA] transition-all duration-200">Schemas</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#64748B]">Connect</h4>
        <div class="flex items-center gap-5 mb-6">
          <a href="https://x.com/CerebrusPulse" target="_blank" rel="noopener noreferrer" class="footer-social-link group" aria-label="Follow on X">
            <svg class="h-6 w-6 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://github.com/0xsl1m/cerebrus-pulse-mcp" target="_blank" rel="noopener noreferrer" class="footer-social-link footer-social-purple group" aria-label="GitHub repository">
            <svg class="h-6 w-6 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
          </a>
          <a href="https://pypi.org/project/cerebrus-pulse-mcp/" target="_blank" rel="noopener noreferrer" class="footer-social-link footer-social-amber group" aria-label="PyPI package">
            <svg class="h-6 w-6 transition-transform duration-300 group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9.585 11.692h4.328s2.432.039 2.432-2.35V5.391S16.714 3 11.936 3C7.362 3 7.647 4.983 7.647 4.983l.006 2.055h4.363v.617H5.92S3 7.28 3 11.894s2.554 4.45 2.554 4.45h1.524v-2.141s-.083-2.554 2.507-2.554v.043zm-.191-5.206a.82.82 0 110-1.638.82.82 0 010 1.638z"/>
              <path d="M14.415 12.308h-4.328s-2.432-.039-2.432 2.35v3.951S7.286 21 12.064 21c4.574 0 4.289-1.983 4.289-1.983l-.006-2.055h-4.363v-.617h6.097S21 16.72 21 12.106s-2.554-4.45-2.554-4.45h-1.524v2.141s.083 2.554-2.507 2.554v-.043zm.191 5.206a.82.82 0 110 1.638.82.82 0 010-1.638z"/>
            </svg>
          </a>
        </div>

        <h4 class="mb-3 text-sm font-semibold uppercase tracking-wider text-[#64748B]">Built With</h4>
        <div class="flex flex-wrap gap-2">
          <span class="tech-pill tech-pill-x402">x402</span>
          <span class="tech-pill" style="background: rgba(255, 20, 147, 0.1); color: #FF69B4; border-color: rgba(255, 20, 147, 0.25);">A2A</span>
          <span class="tech-pill tech-pill-acp">ACP</span>
          <span class="tech-pill tech-pill-acp">Virtuals</span>
          <span class="tech-pill tech-pill-chainlink">Chainlink</span>
          <span class="tech-pill tech-pill-x402">Base</span>
          <span class="tech-pill" style="background: rgba(153, 69, 255, 0.1); color: #9945FF; border-color: rgba(153, 69, 255, 0.25);">Solana</span>
          <span class="tech-pill tech-pill-x402">USDC</span>
          <span class="tech-pill">Hyperliquid</span>
        </div>
      </div>
    </div>

    <div class="duality-line mt-10"></div>

    <p class="mt-6 text-xs text-[#475569] leading-relaxed max-w-3xl">
      Cerebrus Pulse provides market data and technical indicators for informational purposes only. Nothing provided by this API, its documentation, or associated tools constitutes financial advice, investment advice, trading advice, or any other form of professional advice. AI-generated analysis, signals, trade ideas, and sentiment labels are algorithmic outputs — not recommendations to buy, sell, or hold any asset. Cryptocurrency trading involves substantial risk of loss. You are solely responsible for your own trading decisions. Past indicator performance does not guarantee future results.
    </p>
  </div>
</footer>
