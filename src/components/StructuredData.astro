      "price": "0.02",
      "priceCurrency": "USD",
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "0.02",
        "priceCurrency": "USD",
        "unitText": "per query"
      },
      "url": url + "/api/pulse"
    },
