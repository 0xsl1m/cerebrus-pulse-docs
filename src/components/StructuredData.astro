---
interface Props {
  title?: string;
  description?: string;
  url?: string;
}

const {
  title = "Cerebrus Pulse — Real-time Crypto Intelligence API",
  description = "Cerebrus Pulse is a pay-per-query crypto analysis API providing multi-timeframe technical analysis, market sentiment, and funding rate data for 30+ Hyperliquid perpetuals. Two integration paths: x402 micropayments (USDC on Base) for developers and ACP agent commerce (Virtuals Protocol) for autonomous AI agents. Prices from $0.01 per query. No API keys required.",
  url = "https://pulse.openclaw.ai",
} = Astro.props;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "OpenClaw",
  "url": "https://openclaw.ai",
  "brand": {
    "@type": "Brand",
    "name": "Cerebrus Pulse"
  },
  "description": "OpenClaw builds AI-powered crypto intelligence tools. Cerebrus Pulse is its flagship real-time analysis API for Hyperliquid perpetuals."
};

const webApplicationSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Cerebrus Pulse",
  "url": url,
  "description": description,
  "applicationCategory": "FinanceApplication",
  "applicationSubCategory": "Cryptocurrency Analysis API",
  "operatingSystem": "Any (REST API)",
  "browserRequirements": "HTTP client with x402 SDK support",
  "offers": [
