  "about": {
    "@type": "WebApplication",
    "name": "Cerebrus Pulse"
  },
  "author": {
    "@type": "Organization",
    "name": "OpenClaw"
  },
  "proficiencyLevel": "Beginner",
  "dependencies": "x402 SDK (Python or TypeScript) for micropayments, or ACP SDK for Virtuals Protocol agent integration"
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
