---
const coins = [
  'BTC', 'ETH', 'SOL', 'DOGE', 'XRP', 'ADA', 'AVAX', 'LINK', 'DOT', 'MATIC',
  'ARB', 'OP', 'APT', 'SUI', 'SEI', 'TIA', 'INJ', 'FET', 'NEAR', 'ATOM',
  'FIL', 'AAVE', 'UNI', 'MKR', 'LDO', 'PEPE', 'WIF', 'JUP', 'ONDO', 'RENDER',
];

const timeframes = ['15m', '1h', '4h'];
---

<div class="section-divider"></div>
<section class="landing-section landing-section-alt" id="coins">
  <div class="mx-auto max-w-5xl">
    <h2 class="mb-4 text-center text-3xl font-bold md:text-4xl text-[#E8ECF4]" data-reveal="slide-up">
      <span class="gradient-text">30+ Hyperliquid Perpetuals</span>
    </h2>
    <p class="mb-6 text-center text-[#94A3B8] text-lg" data-reveal="slide-up">Real-time data across three timeframes</p>

    <div class="mb-10 flex items-center justify-center gap-3">
      {timeframes.map((tf) => (
        <span class="tf-pill">{tf}</span>
      ))}
    </div>

    <div class="flex flex-wrap justify-center gap-2.5">
      {coins.map((coin, i) => (
        <span class="coin-chip" data-reveal="wave" style={`transition-delay: ${i * 40}ms`}>{coin}</span>
      ))}
      <span class="coin-chip text-[#64748B]" data-reveal="wave" style={`transition-delay: ${coins.length * 40}ms`}>+ more</span>
    </div>

    <p class="mt-8 text-center text-sm text-[#64748B]">
      Use <code class="text-[#60A5FA] bg-[#0F1D35] px-1.5 py-0.5 rounded text-xs">GET /coins</code> for the live list. It's free.
    </p>
  </div>
</section>
