---
const x402Endpoints = [
  {
    method: 'GET',
    path: '/screener',
    price: '$0.04',
    description: 'Market screener',
    details: 'Scan 30+ coins at once: signal strength, RSI zone, trend direction, vol regime, funding bias, confluence, OI trend. The entry point for market-wide analysis.',
    params: 'top_n=30',
  },
  {
    method: 'GET',
    path: '/pulse/{coin}',
    price: '$0.02',
    description: 'Multi-timeframe technical analysis',
    details: 'RSI, EMAs (20/50/200), ATR, Bollinger Bands, VWAP, Z-score, trend detection, confluence scoring, derivatives data, market regime',
    params: 'timeframes=1h,4h',
  },
  {
    method: 'GET',
    path: '/sentiment',
    price: '$0.01',
    description: 'Market sentiment analysis',
    details: 'Aggregated sentiment labels across the crypto market',
    params: 'none',
  },
  {
    method: 'GET',
    path: '/funding/{coin}',
    price: '$0.01',
    description: 'Funding rate analysis',
    details: 'Historical and current funding rates with annualized projections',
    params: 'lookback_hours=24',
  },
  {
    method: 'GET',
    path: '/oi/{coin}',
    price: '$0.01',
    description: 'Open interest analysis',
    details: 'Current OI, delta over 1h/4h/24h, percentile rank, trend direction, and price-OI divergence signals',
    params: 'none',
  },
  {
    method: 'GET',
    path: '/spread/{coin}',
    price: '$0.008',
    description: 'Spread & liquidity analysis',
    details: 'Bid-ask spread, slippage estimates at $10k-$500k notional, and liquidity scoring. Critical for execution-focused agents.',
    params: 'none',
  },
  {
    method: 'GET',
    path: '/correlation',
    price: '$0.03',
    description: 'Correlation matrix',
    details: 'BTC-alt correlation matrix across top 15 coins, 30-day rolling correlation, regime classification, and sector clustering',
    params: 'none',
  },
  {
    method: 'GET',
    path: '/bundle/{coin}',
    price: '$0.04',
    description: 'Complete analysis bundle',
    details: 'Pulse + Sentiment + Funding + Spread combined in one response. 17% discount vs buying individually.',
    params: 'timeframes=1h,4h',
    highlight: true,
  },
];

const acpTiers = [
  {
    tier: 'Lite',
    price: '$0.10',
    description: 'Quick market snapshot',
    details: 'Summary of current conditions with a directional bias. Ideal for fast decision loops.',
  },
  {
    tier: 'Standard',
    price: '$0.50',
    description: 'Full synthesis report',
    details: 'Multi-timeframe analysis with narrative context, trade ideas, and risk scoring.',
    highlight: true,
  },
  {
    tier: 'Premium',
    price: '$2.00',
    description: 'Deep research analysis',
    details: 'Comprehensive cross-asset analysis with correlation mapping, regime context, and portfolio-level recommendations.',
  },
];

const freeEndpoints = [
  { method: 'GET', path: '/health', description: 'Gateway health status' },
  { method: 'GET', path: '/coins', description: 'List available coins' },
];
---

<div class="section-divider"></div>
<section class="landing-section landing-section-dark" id="pricing">
  <div class="mx-auto max-w-5xl">
    <h2 class="mb-4 text-center text-3xl font-bold md:text-4xl text-[#E8ECF4]" data-reveal="slide-up">
      <span class="gradient-text">Pay Per Query</span>
    </h2>
    <p class="mb-4 text-center text-[#94A3B8] text-base sm:text-lg" data-reveal="slide-up">Two protocols. Same intelligence. Choose your path.</p>
    <p class="mb-8 sm:mb-12 text-center text-sm text-[#64748B]" data-reveal="slide-up">
      x402 for structured data via HTTP. ACP for AI-synthesized insights via Virtuals Protocol.
    </p>

    <!-- x402 Pricing -->
    <div class="flex items-center gap-3 mb-6">
      <span class="hero-badge-x402 !text-xs">x402</span>
      <h3 class="text-base font-semibold text-[#94A3B8]">USDC micropayments on Base</h3>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {x402Endpoints.map((ep) => (
        <div class={`price-card ${ep.highlight ? 'price-card-highlight' : ''}`} data-reveal="stagger">
          <div class="mb-3 flex items-center justify-between">
            <code class="text-sm font-mono">
              <span class="text-[#60A5FA]">{ep.method}</span>{' '}
              <span class="text-[#CBD5E1]">{ep.path}</span>
            </code>
            <span class={ep.highlight ? 'price-badge-acp' : 'price-badge'}>{ep.price} USDC</span>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-[#E8ECF4]">{ep.description}</h3>
          <p class="mb-3 text-sm text-[#94A3B8]">{ep.details}</p>
          {ep.params !== 'none' && (
            <div class="text-xs text-[#64748B]">
              Params: <code class="text-[#94A3B8]">{ep.params}</code>
            </div>
          )}
          {ep.highlight && (
            <div class="mt-3">
              <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-medium"
                    style="background: rgba(59, 130, 246, 0.1); color: #60A5FA; border: 1px solid rgba(59, 130, 246, 0.2);">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.8 6.5 10.866a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z" clip-rule="evenodd"/>
                </svg>
                Best Value -- 20% Discount
              </span>
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="duality-line my-10" data-reveal="grow"></div>

    <!-- ACP Pricing -->
    <div class="flex items-center gap-3 mb-6">
      <span class="hero-badge-acp !text-xs">ACP</span>
      <h3 class="text-base font-semibold text-[#94A3B8]">AI synthesis via Virtuals Protocol</h3>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {acpTiers.map((tier) => (
        <div class={`price-card ${tier.highlight ? 'price-card-highlight' : ''}`} data-reveal="stagger">
          <div class="mb-3 flex items-center justify-between">
            <span class="text-sm font-mono font-semibold text-[#FBBF24]">{tier.tier}</span>
            <span class={tier.highlight ? 'price-badge-acp' : 'price-badge'}>{tier.price}</span>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-[#E8ECF4]">{tier.description}</h3>
          <p class="text-sm text-[#94A3B8]">{tier.details}</p>
          {tier.highlight && (
            <div class="mt-3">
              <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-medium"
                    style="background: rgba(245, 158, 11, 0.1); color: #FBBF24; border: 1px solid rgba(245, 158, 11, 0.2);">
                Most Popular
              </span>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Free Endpoints -->
    <div class="mt-8 rounded-xl p-6" style="background: rgba(17, 24, 39, 0.5); border: 1px solid rgba(30, 41, 59, 0.6);">
      <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-[#64748B]">Free Endpoints</h3>
      <div class="grid gap-3 sm:grid-cols-2">
        {freeEndpoints.map((ep) => (
          <div class="flex items-center gap-3">
            <code class="text-sm font-mono">
              <span class="text-[#60A5FA]">{ep.method}</span>{' '}
              <span class="text-[#CBD5E1]">{ep.path}</span>
            </code>
            <span class="text-sm text-[#64748B]"> -- {ep.description}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
