---
---

<section class="landing-hero pt-24">
  <!-- WebGL Particle Canvas — lightweight ambient depth layer -->
  <canvas id="hero-particles" class="hero-particle-canvas" aria-hidden="true"></canvas>

  <!-- Ambient orbs for depth (parallax layers) -->
  <div class="orb orb-blue" data-parallax="slow"></div>
  <div class="orb orb-amber" data-parallax="slower"></div>
  <div class="orb orb-blue-secondary" data-parallax="medium"></div>

  <!-- Atmospheric background texture -->
  <div class="hero-bg-texture" aria-hidden="true">
    <picture>
      <source srcset="/images/hero-bg.webp" type="image/webp" />
      <img
        src="/images/hero-bg.jpg"
        alt=""
        class="hero-bg-img"
        loading="eager"
        decoding="async"
      />
    </picture>
  </div>

  <!-- 3D Electrified Brain -->
  <div class="brain-container" aria-hidden="true" data-parallax="brain">
    <div class="brain-glow"></div>
    <div class="brain-glow-amber"></div>
    <div class="brain-perspective">
      <svg
        class="brain-svg"
        viewBox="0 0 800 700"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
      >
        <defs>
          <!-- Blue glow filter for left hemisphere -->
          <filter id="glow-blue" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="4" result="blur" />
            <feFlood flood-color="#3B82F6" flood-opacity="0.6" result="color" />
            <feComposite in="color" in2="blur" operator="in" result="shadow" />
            <feMerge>
              <feMergeNode in="shadow" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <!-- Amber glow filter for right hemisphere -->
          <filter id="glow-amber" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="4" result="blur" />
            <feFlood flood-color="#F59E0B" flood-opacity="0.6" result="color" />
            <feComposite in="color" in2="blur" operator="in" result="shadow" />
            <feMerge>
              <feMergeNode in="shadow" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <!-- Intense glow for firing nodes -->
          <filter id="glow-node-blue" x="-100%" y="-100%" width="300%" height="300%">
            <feGaussianBlur stdDeviation="6" result="blur" />
            <feFlood flood-color="#60A5FA" flood-opacity="0.8" result="color" />
            <feComposite in="color" in2="blur" operator="in" result="shadow" />
            <feMerge>
              <feMergeNode in="shadow" />
              <feMergeNode in="shadow" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <filter id="glow-node-amber" x="-100%" y="-100%" width="300%" height="300%">
            <feGaussianBlur stdDeviation="6" result="blur" />
            <feFlood flood-color="#FBBF24" flood-opacity="0.8" result="color" />
            <feComposite in="color" in2="blur" operator="in" result="shadow" />
            <feMerge>
              <feMergeNode in="shadow" />
              <feMergeNode in="shadow" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <!-- Bridge arc glow (dual color) -->
          <filter id="glow-bridge" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="3" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <!-- Gradient for bridge arcs -->
          <linearGradient id="bridge-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#3B82F6" />
            <stop offset="50%" stop-color="#A78BFA" />
            <stop offset="100%" stop-color="#F59E0B" />
          </linearGradient>

          <linearGradient id="bridge-gradient-2" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#60A5FA" />
            <stop offset="50%" stop-color="#C084FC" />
            <stop offset="100%" stop-color="#FBBF24" />
          </linearGradient>
        </defs>

        <!-- ============================================ -->
        <!-- LEFT HEMISPHERE OUTLINE (Blue / x402)       -->
        <!-- ============================================ -->
        <g class="hemisphere-left">
          <!-- Outer brain contour - left hemisphere -->
          <path
            class="brain-outline brain-outline-blue"
            d="M400 120
               C370 100, 310 70, 250 80
               C190 90, 140 140, 120 200
               C100 260, 95 320, 110 380
               C120 420, 105 460, 115 500
               C125 530, 145 555, 170 570
               C200 590, 240 600, 280 595
               C320 585, 360 560, 385 530
               C395 510, 400 490, 400 460
               L400 120Z"
            stroke="#3B82F6"
            stroke-width="1.5"
            fill="none"
            opacity="0.6"
          />
          <!-- Frontal lobe fold -->
          <path
            class="brain-fold brain-fold-blue"
            d="M380 140 C340 135, 290 120, 245 135 C210 148, 185 175, 170 200"
            stroke="#3B82F6"
            stroke-width="1"
            fill="none"
            opacity="0.3"
          />
          <!-- Parietal lobe fold -->
          <path
            class="brain-fold brain-fold-blue"
            d="M390 180 C360 195, 310 200, 275 195 C240 190, 200 210, 160 250"
            stroke="#3B82F6"
            stroke-width="1"
            fill="none"
            opacity="0.3"
          />
          <!-- Temporal lobe fold -->
          <path
            class="brain-fold brain-fold-blue"
            d="M395 300 C360 310, 300 315, 250 305 C200 295, 155 320, 130 360"
            stroke="#3B82F6"
            stroke-width="1"
            fill="none"
            opacity="0.25"
          />
          <!-- Occipital fold -->
          <path
            class="brain-fold brain-fold-blue"
            d="M395 400 C370 415, 330 430, 290 440 C250 450, 210 465, 185 500"
            stroke="#3B82F6"
            stroke-width="1"
            fill="none"
            opacity="0.25"
          />
          <!-- Central sulcus -->
          <path
            class="brain-fold brain-fold-blue"
            d="M360 130 C340 180, 310 240, 290 300 C270 360, 260 420, 270 470"
            stroke="#3B82F6"
            stroke-width="0.8"
            fill="none"
            opacity="0.2"
          />
          <!-- Lateral sulcus -->
          <path
            class="brain-fold brain-fold-blue"
            d="M380 250 C340 270, 280 290, 230 310 C190 325, 155 355, 135 400"
            stroke="#3B82F6"
            stroke-width="0.8"
            fill="none"
            opacity="0.2"
          />
        </g>

        <!-- ============================================ -->
        <!-- RIGHT HEMISPHERE OUTLINE (Amber / ACP)      -->
        <!-- ============================================ -->
        <g class="hemisphere-right">
          <!-- Outer brain contour - right hemisphere -->
          <path
            class="brain-outline brain-outline-amber"
            d="M400 120
               C430 100, 490 70, 550 80
               C610 90, 660 140, 680 200
               C700 260, 705 320, 690 380
               C680 420, 695 460, 685 500
               C675 530, 655 555, 630 570
               C600 590, 560 600, 520 595
               C480 585, 440 560, 415 530
               C405 510, 400 490, 400 460
               L400 120Z"
            stroke="#F59E0B"
            stroke-width="1.5"
            fill="none"
            opacity="0.6"
          />
          <!-- Frontal lobe fold -->
          <path
            class="brain-fold brain-fold-amber"
            d="M420 140 C460 135, 510 120, 555 135 C590 148, 615 175, 630 200"
            stroke="#F59E0B"
            stroke-width="1"
            fill="none"
            opacity="0.3"
          />
          <!-- Parietal lobe fold -->
          <path
            class="brain-fold brain-fold-amber"
            d="M410 180 C440 195, 490 200, 525 195 C560 190, 600 210, 640 250"
            stroke="#F59E0B"
            stroke-width="1"
            fill="none"
            opacity="0.3"
          />
          <!-- Temporal lobe fold -->
          <path
            class="brain-fold brain-fold-amber"
            d="M405 300 C440 310, 500 315, 550 305 C600 295, 645 320, 670 360"
            stroke="#F59E0B"
            stroke-width="1"
            fill="none"
            opacity="0.25"
          />
          <!-- Occipital fold -->
          <path
            class="brain-fold brain-fold-amber"
            d="M405 400 C430 415, 470 430, 510 440 C550 450, 590 465, 615 500"
            stroke="#F59E0B"
            stroke-width="1"
            fill="none"
            opacity="0.25"
          />
          <!-- Central sulcus -->
          <path
            class="brain-fold brain-fold-amber"
            d="M440 130 C460 180, 490 240, 510 300 C530 360, 540 420, 530 470"
            stroke="#F59E0B"
            stroke-width="0.8"
            fill="none"
            opacity="0.2"
          />
          <!-- Lateral sulcus -->
          <path
            class="brain-fold brain-fold-amber"
            d="M420 250 C460 270, 520 290, 570 310 C610 325, 645 355, 665 400"
            stroke="#F59E0B"
            stroke-width="0.8"
            fill="none"
            opacity="0.2"
          />
        </g>

        <!-- ============================================ -->
        <!-- NEURAL NETWORK — LEFT (Blue paths + nodes)  -->
        <!-- ============================================ -->
        <g class="neural-net-left" filter="url(#glow-blue)">
          <!-- Neural pathways (lines between nodes) -->
          <path class="neural-path neural-path-blue np-b1" d="M300 160 L250 220 L200 280" stroke="#3B82F6" stroke-width="1.2" opacity="0.5" />
          <path class="neural-path neural-path-blue np-b2" d="M350 180 L280 250 L220 340" stroke="#3B82F6" stroke-width="1" opacity="0.4" />
          <path class="neural-path neural-path-blue np-b3" d="M370 220 L310 300 L260 380" stroke="#3B82F6" stroke-width="1.2" opacity="0.5" />
          <path class="neural-path neural-path-blue np-b4" d="M340 280 L270 350 L210 420" stroke="#3B82F6" stroke-width="1" opacity="0.4" />
          <path class="neural-path neural-path-blue np-b5" d="M360 350 L300 420 L250 490" stroke="#3B82F6" stroke-width="1.2" opacity="0.5" />
          <path class="neural-path neural-path-blue np-b6" d="M300 160 L350 180" stroke="#3B82F6" stroke-width="0.8" opacity="0.35" />
          <path class="neural-path neural-path-blue np-b7" d="M250 220 L280 250" stroke="#3B82F6" stroke-width="0.8" opacity="0.35" />
          <path class="neural-path neural-path-blue np-b8" d="M200 280 L220 340" stroke="#3B82F6" stroke-width="0.8" opacity="0.35" />
          <path class="neural-path neural-path-blue np-b9" d="M310 300 L340 280" stroke="#3B82F6" stroke-width="0.8" opacity="0.35" />
          <path class="neural-path neural-path-blue np-b10" d="M260 380 L270 350" stroke="#3B82F6" stroke-width="0.8" opacity="0.35" />
          <path class="neural-path neural-path-blue np-b11" d="M300 420 L340 280" stroke="#3B82F6" stroke-width="0.8" opacity="0.3" />
          <path class="neural-path neural-path-blue np-b12" d="M210 420 L250 490" stroke="#3B82F6" stroke-width="0.8" opacity="0.3" />
          <!-- Cross connections -->
          <path class="neural-path neural-path-blue np-b13" d="M300 160 L370 220" stroke="#3B82F6" stroke-width="0.6" opacity="0.25" />
          <path class="neural-path neural-path-blue np-b14" d="M220 340 L260 380" stroke="#3B82F6" stroke-width="0.6" opacity="0.25" />
          <path class="neural-path neural-path-blue np-b15" d="M200 280 L260 380" stroke="#3B82F6" stroke-width="0.6" opacity="0.25" />

          <!-- Neural nodes (firing dots) — left hemisphere -->
          <circle class="neural-node node-blue node-fire-b1" cx="300" cy="160" r="4" fill="#60A5FA" opacity="0.7" />
          <circle class="neural-node node-blue node-fire-b2" cx="250" cy="220" r="3.5" fill="#60A5FA" opacity="0.6" />
          <circle class="neural-node node-blue node-fire-b3" cx="200" cy="280" r="3" fill="#60A5FA" opacity="0.5" />
          <circle class="neural-node node-blue node-fire-b4" cx="350" cy="180" r="4" fill="#60A5FA" opacity="0.7" />
          <circle class="neural-node node-blue node-fire-b5" cx="280" cy="250" r="3" fill="#60A5FA" opacity="0.5" />
          <circle class="neural-node node-blue node-fire-b6" cx="370" cy="220" r="3.5" fill="#60A5FA" opacity="0.6" />
          <circle class="neural-node node-blue node-fire-b7" cx="310" cy="300" r="4.5" fill="#60A5FA" opacity="0.8" />
          <circle class="neural-node node-blue node-fire-b8" cx="220" cy="340" r="3" fill="#60A5FA" opacity="0.5" />
          <circle class="neural-node node-blue node-fire-b9" cx="340" cy="280" r="3.5" fill="#60A5FA" opacity="0.6" />
          <circle class="neural-node node-blue node-fire-b10" cx="260" cy="380" r="4" fill="#60A5FA" opacity="0.7" />
          <circle class="neural-node node-blue node-fire-b11" cx="270" cy="350" r="3" fill="#60A5FA" opacity="0.5" />
          <circle class="neural-node node-blue node-fire-b12" cx="360" cy="350" r="3.5" fill="#60A5FA" opacity="0.6" />
          <circle class="neural-node node-blue node-fire-b13" cx="300" cy="420" r="4" fill="#60A5FA" opacity="0.7" />
          <circle class="neural-node node-blue node-fire-b14" cx="210" cy="420" r="3" fill="#60A5FA" opacity="0.5" />
          <circle class="neural-node node-blue node-fire-b15" cx="250" cy="490" r="3.5" fill="#60A5FA" opacity="0.6" />
        </g>

        <!-- ============================================ -->
        <!-- NEURAL NETWORK — RIGHT (Amber paths + nodes)-->
        <!-- ============================================ -->
        <g class="neural-net-right" filter="url(#glow-amber)">
          <!-- Neural pathways (lines between nodes) -->
          <path class="neural-path neural-path-amber np-a1" d="M500 160 L550 220 L600 280" stroke="#F59E0B" stroke-width="1.2" opacity="0.5" />
          <path class="neural-path neural-path-amber np-a2" d="M450 180 L520 250 L580 340" stroke="#F59E0B" stroke-width="1" opacity="0.4" />
          <path class="neural-path neural-path-amber np-a3" d="M430 220 L490 300 L540 380" stroke="#F59E0B" stroke-width="1.2" opacity="0.5" />
          <path class="neural-path neural-path-amber np-a4" d="M460 280 L530 350 L590 420" stroke="#F59E0B" stroke-width="1" opacity="0.4" />
          <path class="neural-path neural-path-amber np-a5" d="M440 350 L500 420 L550 490" stroke="#F59E0B" stroke-width="1.2" opacity="0.5" />
          <path class="neural-path neural-path-amber np-a6" d="M500 160 L450 180" stroke="#F59E0B" stroke-width="0.8" opacity="0.35" />
          <path class="neural-path neural-path-amber np-a7" d="M550 220 L520 250" stroke="#F59E0B" stroke-width="0.8" opacity="0.35" />
          <path class="neural-path neural-path-amber np-a8" d="M600 280 L580 340" stroke="#F59E0B" stroke-width="0.8" opacity="0.35" />
          <path class="neural-path neural-path-amber np-a9" d="M490 300 L460 280" stroke="#F59E0B" stroke-width="0.8" opacity="0.35" />
          <path class="neural-path neural-path-amber np-a10" d="M540 380 L530 350" stroke="#F59E0B" stroke-width="0.8" opacity="0.35" />
          <path class="neural-path neural-path-amber np-a11" d="M500 420 L460 280" stroke="#F59E0B" stroke-width="0.8" opacity="0.3" />
          <path class="neural-path neural-path-amber np-a12" d="M590 420 L550 490" stroke="#F59E0B" stroke-width="0.8" opacity="0.3" />
          <!-- Cross connections -->
          <path class="neural-path neural-path-amber np-a13" d="M500 160 L430 220" stroke="#F59E0B" stroke-width="0.6" opacity="0.25" />
          <path class="neural-path neural-path-amber np-a14" d="M580 340 L540 380" stroke="#F59E0B" stroke-width="0.6" opacity="0.25" />
          <path class="neural-path neural-path-amber np-a15" d="M600 280 L540 380" stroke="#F59E0B" stroke-width="0.6" opacity="0.25" />

          <!-- Neural nodes (firing dots) — right hemisphere -->
          <circle class="neural-node node-amber node-fire-a1" cx="500" cy="160" r="4" fill="#FBBF24" opacity="0.7" />
          <circle class="neural-node node-amber node-fire-a2" cx="550" cy="220" r="3.5" fill="#FBBF24" opacity="0.6" />
          <circle class="neural-node node-amber node-fire-a3" cx="600" cy="280" r="3" fill="#FBBF24" opacity="0.5" />
          <circle class="neural-node node-amber node-fire-a4" cx="450" cy="180" r="4" fill="#FBBF24" opacity="0.7" />
          <circle class="neural-node node-amber node-fire-a5" cx="520" cy="250" r="3" fill="#FBBF24" opacity="0.5" />
          <circle class="neural-node node-amber node-fire-a6" cx="430" cy="220" r="3.5" fill="#FBBF24" opacity="0.6" />
          <circle class="neural-node node-amber node-fire-a7" cx="490" cy="300" r="4.5" fill="#FBBF24" opacity="0.8" />
          <circle class="neural-node node-amber node-fire-a8" cx="580" cy="340" r="3" fill="#FBBF24" opacity="0.5" />
          <circle class="neural-node node-amber node-fire-a9" cx="460" cy="280" r="3.5" fill="#FBBF24" opacity="0.6" />
          <circle class="neural-node node-amber node-fire-a10" cx="540" cy="380" r="4" fill="#FBBF24" opacity="0.7" />
          <circle class="neural-node node-amber node-fire-a11" cx="530" cy="350" r="3" fill="#FBBF24" opacity="0.5" />
          <circle class="neural-node node-amber node-fire-a12" cx="440" cy="350" r="3.5" fill="#FBBF24" opacity="0.6" />
          <circle class="neural-node node-amber node-fire-a13" cx="500" cy="420" r="4" fill="#FBBF24" opacity="0.7" />
          <circle class="neural-node node-amber node-fire-a14" cx="590" cy="420" r="3" fill="#FBBF24" opacity="0.5" />
          <circle class="neural-node node-amber node-fire-a15" cx="550" cy="490" r="3.5" fill="#FBBF24" opacity="0.6" />
        </g>

        <!-- ============================================ -->
        <!-- BRIDGE ARCS (Corpus callosum — connecting)  -->
        <!-- ============================================ -->
        <g class="bridge-arcs" filter="url(#glow-bridge)">
          <path class="bridge-arc bridge-arc-1" d="M370 200 C385 180, 415 180, 430 200" stroke="url(#bridge-gradient)" stroke-width="1.5" fill="none" opacity="0.6" />
          <path class="bridge-arc bridge-arc-2" d="M360 270 C380 245, 420 245, 440 270" stroke="url(#bridge-gradient-2)" stroke-width="1.2" fill="none" opacity="0.5" />
          <path class="bridge-arc bridge-arc-3" d="M365 340 C382 315, 418 315, 435 340" stroke="url(#bridge-gradient)" stroke-width="1.5" fill="none" opacity="0.6" />
          <path class="bridge-arc bridge-arc-4" d="M370 410 C385 388, 415 388, 430 410" stroke="url(#bridge-gradient-2)" stroke-width="1.2" fill="none" opacity="0.5" />
          <path class="bridge-arc bridge-arc-5" d="M375 470 C388 450, 412 450, 425 470" stroke="url(#bridge-gradient)" stroke-width="1" fill="none" opacity="0.4" />
          <!-- Wider bridge arcs for depth -->
          <path class="bridge-arc bridge-arc-6" d="M340 240 C370 200, 430 200, 460 240" stroke="url(#bridge-gradient)" stroke-width="0.8" fill="none" opacity="0.25" />
          <path class="bridge-arc bridge-arc-7" d="M350 380 C375 350, 425 350, 450 380" stroke="url(#bridge-gradient-2)" stroke-width="0.8" fill="none" opacity="0.25" />
        </g>

        <!-- ============================================ -->
        <!-- ELECTRICAL SPARK PARTICLES                   -->
        <!-- ============================================ -->
        <g class="spark-particles">
          <!-- Blue sparks on left neural paths -->
          <circle class="spark spark-blue spark-travel-1" cx="0" cy="0" r="2.5" fill="#93C5FD" opacity="0">
            <animateMotion dur="2.5s" repeatCount="indefinite" begin="0s">
              <mpath href="#spark-path-b1" />
            </animateMotion>
            <animate attributeName="opacity" values="0;0.9;0.9;0" dur="2.5s" repeatCount="indefinite" begin="0s" />
            <animate attributeName="r" values="1.5;3;1.5" dur="2.5s" repeatCount="indefinite" begin="0s" />
          </circle>
          <circle class="spark spark-blue spark-travel-2" cx="0" cy="0" r="2" fill="#93C5FD" opacity="0">
            <animateMotion dur="3s" repeatCount="indefinite" begin="0.8s">
              <mpath href="#spark-path-b2" />
            </animateMotion>
            <animate attributeName="opacity" values="0;0.8;0.8;0" dur="3s" repeatCount="indefinite" begin="0.8s" />
            <animate attributeName="r" values="1;2.5;1" dur="3s" repeatCount="indefinite" begin="0.8s" />
          </circle>
          <circle class="spark spark-blue spark-travel-3" cx="0" cy="0" r="2" fill="#93C5FD" opacity="0">
            <animateMotion dur="2.8s" repeatCount="indefinite" begin="1.6s">
              <mpath href="#spark-path-b3" />
            </animateMotion>
            <animate attributeName="opacity" values="0;0.85;0.85;0" dur="2.8s" repeatCount="indefinite" begin="1.6s" />
            <animate attributeName="r" values="1;2.5;1" dur="2.8s" repeatCount="indefinite" begin="1.6s" />
          </circle>

          <!-- Amber sparks on right neural paths -->
          <circle class="spark spark-amber spark-travel-4" cx="0" cy="0" r="2.5" fill="#FCD34D" opacity="0">
            <animateMotion dur="2.5s" repeatCount="indefinite" begin="0.3s">
              <mpath href="#spark-path-a1" />
            </animateMotion>
            <animate attributeName="opacity" values="0;0.9;0.9;0" dur="2.5s" repeatCount="indefinite" begin="0.3s" />
            <animate attributeName="r" values="1.5;3;1.5" dur="2.5s" repeatCount="indefinite" begin="0.3s" />
          </circle>
          <circle class="spark spark-amber spark-travel-5" cx="0" cy="0" r="2" fill="#FCD34D" opacity="0">
            <animateMotion dur="3s" repeatCount="indefinite" begin="1.1s">
              <mpath href="#spark-path-a2" />
            </animateMotion>
            <animate attributeName="opacity" values="0;0.8;0.8;0" dur="3s" repeatCount="indefinite" begin="1.1s" />
            <animate attributeName="r" values="1;2.5;1" dur="3s" repeatCount="indefinite" begin="1.1s" />
          </circle>
          <circle class="spark spark-amber spark-travel-6" cx="0" cy="0" r="2" fill="#FCD34D" opacity="0">
            <animateMotion dur="2.8s" repeatCount="indefinite" begin="1.9s">
              <mpath href="#spark-path-a3" />
            </animateMotion>
            <animate attributeName="opacity" values="0;0.85;0.85;0" dur="2.8s" repeatCount="indefinite" begin="1.9s" />
            <animate attributeName="r" values="1;2.5;1" dur="2.8s" repeatCount="indefinite" begin="1.9s" />
          </circle>

          <!-- Bridge sparks (crossing between hemispheres) -->
          <circle class="spark spark-bridge" cx="0" cy="0" r="2" fill="#C084FC" opacity="0">
            <animateMotion dur="1.8s" repeatCount="indefinite" begin="0.5s">
              <mpath href="#spark-path-bridge1" />
            </animateMotion>
            <animate attributeName="opacity" values="0;1;1;0" dur="1.8s" repeatCount="indefinite" begin="0.5s" />
            <animate attributeName="r" values="1;3;1" dur="1.8s" repeatCount="indefinite" begin="0.5s" />
          </circle>
          <circle class="spark spark-bridge" cx="0" cy="0" r="2" fill="#C084FC" opacity="0">
            <animateMotion dur="2s" repeatCount="indefinite" begin="1.3s">
              <mpath href="#spark-path-bridge2" />
            </animateMotion>
