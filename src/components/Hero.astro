---
import Brain3D from './Brain3D.astro';
---

<section class="landing-hero pt-24">
  <!-- CRT Scanline overlay -->
  <div class="hero-scanlines" aria-hidden="true"></div>

  <!-- Reactive grid canvas — mouse-following glow on grid intersections -->
  <canvas id="hero-grid" class="hero-grid-canvas" aria-hidden="true"></canvas>

  <!-- WebGL Particle Canvas — lightweight ambient depth layer -->
  <canvas id="hero-particles" class="hero-particle-canvas" aria-hidden="true"></canvas>

  <!-- Ambient orbs for depth (parallax layers) -->
  <div class="orb orb-blue" data-parallax="slow"></div>
  <div class="orb orb-amber" data-parallax="slower"></div>
  <div class="orb orb-blue-secondary" data-parallax="medium"></div>

  <!-- Atmospheric background texture -->
  <div class="hero-bg-texture" aria-hidden="true">
    <picture>
      <source srcset="/images/hero-bg.webp" type="image/webp" />
      <img
        src="/images/hero-bg.jpg"
        alt=""
        class="hero-bg-img"
        loading="eager"
        decoding="async"
      />
    </picture>
  </div>

  <!-- 3D Electrified Brain (Three.js) -->
  <div class="brain-container" aria-hidden="true" data-parallax="brain">
    <div class="brain-glow"></div>
    <div class="brain-glow-amber"></div>
    <div class="brain-perspective">
      <Brain3D />
    </div>
  </div>

  <div class="hero-text-backdrop relative z-10 w-full mx-auto max-w-5xl px-4 sm:px-6 py-12 sm:py-16 md:py-24 text-center box-border overflow-hidden" data-parallax="hero-text">
    <!-- Trinity protocol badges -->
    <div class="mb-6 sm:mb-8 flex flex-wrap items-center justify-center gap-2 sm:gap-3 animate-slide-up">
      <span class="hero-badge-x402">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/>
        </svg>
        x402 on Base + Solana
      </span>
      <span class="text-[#475569] text-sm font-mono">+</span>
      <span class="hero-badge-a2a">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.586 4.586a2 2 0 112.828 2.828l-3 3a2 2 0 01-2.828 0 1 1 0 00-1.414 1.414 4 4 0 005.656 0l3-3a4 4 0 00-5.656-5.656l-1.5 1.5a1 1 0 101.414 1.414l1.5-1.5zm-5 5a2 2 0 012.828 0 1 1 0 101.414-1.414 4 4 0 00-5.656 0l-3 3a4 4 0 105.656 5.656l1.5-1.5a1 1 0 10-1.414-1.414l-1.5 1.5a2 2 0 11-2.828-2.828l3-3z" clip-rule="evenodd"/>
        </svg>
        A2A Protocol
      </span>
      <span class="text-[#475569] text-sm font-mono">+</span>
      <span class="hero-badge-acp">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path d="M13 7H7v6h6V7z"/>
          <path fill-rule="evenodd" d="M7 2a1 1 0 012 0v1h2V2a1 1 0 112 0v1h2a2 2 0 012 2v2h1a1 1 0 110 2h-1v2h1a1 1 0 110 2h-1v2a2 2 0 01-2 2h-2v1a1 1 0 11-2 0v-1H9v1a1 1 0 11-2 0v-1H5a2 2 0 01-2-2v-2H2a1 1 0 110-2h1V9H2a1 1 0 010-2h1V5a2 2 0 012-2h2V2zM5 5h10v10H5V5z" clip-rule="evenodd"/>
        </svg>
        ACP on Virtuals
      </span>
    </div>

    <!-- Main headline — stacked on mobile, inline on desktop -->
    <h1 class="hero-glitch-wrapper mb-4 sm:mb-6 font-extrabold leading-tight animate-slide-up-delay-1">
      <span class="hero-headline-wrap hero-headline-stack text-4xl sm:text-4xl md:text-7xl lg:text-8xl">
        <span class="gradient-text hero-glitch" data-text="Cerebrus"><span class="hero-glitch-text">Cerebrus</span></span>
        <img src="/images/pulse-logo.png" alt="" class="hero-headline-logo" />
        <span class="hero-pulse-row">
          <span class="gradient-text hero-glitch" data-text="Pulse"><span class="hero-glitch-text">Pulse</span></span>
          <span class="xyz-tag xyz-tag-desktop">.xyz</span>
        </span>
        <span class="xyz-tag xyz-tag-mobile">.xyz</span>
      </span>
    </h1>

    <!-- Tagline -->
    <p class="mx-auto mb-3 sm:mb-4 max-w-2xl text-base sm:text-lg text-[#CBD5E1] md:text-2xl animate-slide-up-delay-1">
      Three protocols. One intelligence layer. <span class="text-[#60A5FA] font-semibold">Pay per query.</span>
    </p>
    <p class="mx-auto mb-8 sm:mb-10 max-w-xl text-sm sm:text-base text-[#94A3B8] animate-slide-up-delay-2">
      Multi-timeframe technical analysis for 50+ Hyperliquid perpetuals.
      <span class="text-[#60A5FA]">x402 micropayments</span> for developers. <span class="text-[#FF69B4]">A2A protocol</span> for agent networks. <span class="text-[#FBBF24]">ACP commerce</span> for autonomous AI.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col items-center justify-center gap-3 sm:gap-4 sm:flex-row animate-slide-up-delay-2 w-full">
      <a href="/quickstart" class="btn-primary text-base sm:text-lg text-center">
        Get Started
      </a>
      <a href="#pricing" class="btn-secondary text-base sm:text-lg text-center">
        View Pricing
      </a>
    </div>

    <!-- Code example -->
    <div class="mt-10 sm:mt-16 mx-auto max-w-full sm:max-w-2xl animate-slide-up-delay-3 min-w-0">
      <div class="code-block-wrapper text-left min-w-0 overflow-hidden">
        <div class="flex items-center gap-2 border-b border-[#1E293B] px-4 py-2.5">
          <div class="h-3 w-3 rounded-full bg-[#EF4444]/60"></div>
          <div class="h-3 w-3 rounded-full bg-[#F59E0B]/60"></div>
          <div class="h-3 w-3 rounded-full bg-[#22C55E]/60"></div>
          <span class="ml-2 text-xs text-[#64748B] font-mono">terminal</span>
        </div>
        <pre class="p-3 sm:p-4 text-xs sm:text-sm leading-relaxed overflow-x-auto"><code class="text-[#CBD5E1]"><span class="text-[#64748B]">$</span> curl https://api.cerebruspulse.xyz/pulse/BTC?timeframes=1h,4h
<span class="text-[#64748B]"># 402 Payment Required  &#8594;  x402 SDK auto-pays $0.02 USDC</span>

<span class="text-[#60A5FA]">&#123;</span>
  <span class="text-[#93C5FD]">"coin"</span>: <span class="text-[#FBBF24]">"BTC"</span>,
  <span class="text-[#93C5FD]">"price"</span>: &#123; <span class="text-[#93C5FD]">"current"</span>: <span class="text-[#60A5FA]">98765.43</span> &#125;,
  <span class="text-[#93C5FD]">"confluence"</span>: &#123;
    <span class="text-[#93C5FD]">"score"</span>: <span class="text-[#60A5FA]">0.75</span>,
    <span class="text-[#93C5FD]">"bias"</span>: <span class="text-[#FBBF24]">"bullish"</span>
  <span class="text-[#60A5FA]">&#125;</span>
  ...
<span class="text-[#60A5FA]">&#125;</span></code></pre>
      </div>
    </div>
  </div>
</section>

<script>
  // Reactive Grid — mouse-following glow on grid intersections
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const canvas = document.getElementById('hero-grid');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const GRID = 60;
    const INFLUENCE = 220;     // mouse glow radius in px
    const RIPPLE_SPEED = 180;  // px per second
    const RIPPLE_LIFE = 1.2;   // seconds
    const MAX_RIPPLES = 6;

    let width, height, animId;
    let mouseX = -9999, mouseY = -9999;
    let ripples = [];
    let lastMoveTime = 0;

    function resize() {
      width = canvas.width = canvas.offsetWidth;
      height = canvas.height = canvas.offsetHeight;
    }

    // Track mouse over entire hero section
    const hero = canvas.closest('.landing-hero');
    if (hero) {
      hero.style.pointerEvents = 'auto';
      hero.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        mouseX = e.clientX - rect.left;
        mouseY = e.clientY - rect.top;
        // Spawn ripple on significant movement (throttled)
        const now = performance.now();
        if (now - lastMoveTime > 300 && ripples.length < MAX_RIPPLES) {
          ripples.push({ x: mouseX, y: mouseY, t: 0 });
          lastMoveTime = now;
        }
      });
      hero.addEventListener('mouseleave', () => {
        mouseX = -9999;
        mouseY = -9999;
      });
    }

    function draw(timestamp) {
      ctx.clearRect(0, 0, width, height);
      const dt = 1 / 60;
      const cols = Math.ceil(width / GRID) + 1;
      const rows = Math.ceil(height / GRID) + 1;

      // Update ripples
      for (let i = ripples.length - 1; i >= 0; i--) {
        ripples[i].t += dt;
        if (ripples[i].t > RIPPLE_LIFE) ripples.splice(i, 1);
      }

      // Draw grid intersection dots + lines near mouse
      for (let row = 0; row < rows; row++) {
        for (let col = 0; col < cols; col++) {
          const x = col * GRID;
          const y = row * GRID;

          // Distance to mouse
          const dx = x - mouseX;
          const dy = y - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);

          // Mouse proximity glow (0 to 1)
          const mouseGlow = Math.max(0, 1 - dist / INFLUENCE);

          // Ripple contribution
          let rippleGlow = 0;
          for (const rip of ripples) {
            const rdx = x - rip.x;
            const rdy = y - rip.y;
            const rdist = Math.sqrt(rdx * rdx + rdy * rdy);
            const rippleRadius = rip.t * RIPPLE_SPEED;
            const ringDist = Math.abs(rdist - rippleRadius);
            const fade = 1 - rip.t / RIPPLE_LIFE;
            if (ringDist < 40) {
              rippleGlow += (1 - ringDist / 40) * fade * 0.6;
            }
          }

          const totalGlow = Math.min(1, mouseGlow + rippleGlow);

          // Ambient baseline — faint dots always visible
          const baseAlpha = 0.04;
          const alpha = baseAlpha + totalGlow * 0.55;
          if (alpha < 0.01) continue;

          // Draw intersection dot
          const dotSize = 1.2 + totalGlow * 2.5;
          ctx.beginPath();
          ctx.arc(x, y, dotSize, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(96, 165, 250, ${alpha})`;
          ctx.fill();

          // Draw cross-hair lines at glowing intersections
          if (totalGlow > 0.1) {
            const lineLen = 8 + totalGlow * 14;
            const lineAlpha = totalGlow * 0.3;
            ctx.strokeStyle = `rgba(96, 165, 250, ${lineAlpha})`;
            ctx.lineWidth = 0.8;
            ctx.beginPath();
            ctx.moveTo(x - lineLen, y);
            ctx.lineTo(x + lineLen, y);
            ctx.moveTo(x, y - lineLen);
            ctx.lineTo(x, y + lineLen);
            ctx.stroke();
          }

          // Halo on strongly lit nodes
          if (totalGlow > 0.4) {
            const haloR = 6 + totalGlow * 12;
            const grad = ctx.createRadialGradient(x, y, 0, x, y, haloR);
            grad.addColorStop(0, `rgba(96, 165, 250, ${totalGlow * 0.2})`);
            grad.addColorStop(1, 'rgba(96, 165, 250, 0)');
            ctx.beginPath();
            ctx.arc(x, y, haloR, 0, Math.PI * 2);
            ctx.fillStyle = grad;
            ctx.fill();
          }
        }
      }

      // Draw faint grid lines connecting nearby glowing intersections
      ctx.lineWidth = 0.6;
      for (let row = 0; row < rows; row++) {
        for (let col = 0; col < cols; col++) {
          const x = col * GRID;
          const y = row * GRID;
          const dx = x - mouseX;
          const dy = y - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const glow = Math.max(0, 1 - dist / INFLUENCE);
          if (glow < 0.08) continue;

          const lineAlpha = glow * 0.15;
          ctx.strokeStyle = `rgba(96, 165, 250, ${lineAlpha})`;

          // Right neighbor
          if (col < cols - 1) {
            ctx.beginPath();
            ctx.moveTo(x, y);
            ctx.lineTo(x + GRID, y);
            ctx.stroke();
          }
          // Bottom neighbor
          if (row < rows - 1) {
            ctx.beginPath();
            ctx.moveTo(x, y);
            ctx.lineTo(x, y + GRID);
            ctx.stroke();
          }
        }
      }

      animId = requestAnimationFrame(draw);
    }

    // Pause when off-screen
    const gridObserver = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        if (!animId) animId = requestAnimationFrame(draw);
      } else {
        if (animId) {
          cancelAnimationFrame(animId);
          animId = null;
        }
      }
    }, { threshold: 0 });

    resize();
    gridObserver.observe(canvas);
    window.addEventListener('resize', resize);
  })();
</script>

<script>
  // Reactive Particle Network — mouse-interactive depth layer
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const canvas = document.getElementById('hero-particles');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width, height, particles, animId;
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const PARTICLE_COUNT = isMobile ? 60 : 140;
    const CONNECTION_DIST = isMobile ? 120 : 180;
    const MOUSE_RADIUS = 250;       // glow influence radius
    const MOUSE_REPEL = 120;        // repulsion radius
    const MOUSE_REPEL_FORCE = 1.8;  // repulsion strength
    // Tone down connections on mobile — fewer particles in less space
    const CONN_BASE_OPACITY = isMobile ? 0.07 : 0.18;
    const CONN_MOUSE_BOOST = isMobile ? 0 : 0.25;

    let mouseX = -9999, mouseY = -9999;
    let mouseActive = false;

    // Mouse reactivity — desktop only (touch scroll ≠ hover intent)
    const hero = canvas.closest('.landing-hero');
    if (hero && !isMobile) {
      hero.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        mouseX = e.clientX - rect.left;
        mouseY = e.clientY - rect.top;
        mouseActive = true;
      });
      hero.addEventListener('mouseleave', () => {
        mouseActive = false;
        mouseX = -9999;
        mouseY = -9999;
      });
    }

    function resize() {
      width = canvas.width = canvas.offsetWidth;
      height = canvas.height = canvas.offsetHeight;
    }

    function createParticles() {
      particles = [];
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        const roll = Math.random();
        let color;
        if (roll > 0.7) color = { r: 245, g: 158, b: 11 };       // amber 30%
        else if (roll > 0.4) color = { r: 59, g: 130, b: 246 };   // blue 30%
        else if (roll > 0.15) color = { r: 255, g: 20, b: 147 };  // pink 25%
        else color = { r: 167, g: 139, b: 250 };                  // violet 15%
        particles.push({
          x: Math.random() * width,
          y: Math.random() * height,
          vx: (Math.random() - 0.5) * 0.5,
          vy: (Math.random() - 0.5) * 0.4,
          baseVx: (Math.random() - 0.5) * 0.5,
          baseVy: (Math.random() - 0.5) * 0.4,
          r: Math.random() * (isMobile ? 1.8 : 2.5) + 0.8,
          color,
          alpha: Math.random() * (isMobile ? 0.3 : 0.5) + 0.15,
        });
      }
    }

    function draw() {
      // Faint trails
      ctx.fillStyle = 'rgba(11, 15, 26, 0.18)';
      ctx.fillRect(0, 0, width, height);

      // Update particles — apply mouse repulsion
      for (const p of particles) {
        if (mouseActive) {
          const dx = p.x - mouseX;
          const dy = p.y - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < MOUSE_REPEL && dist > 0) {
            const force = (1 - dist / MOUSE_REPEL) * MOUSE_REPEL_FORCE;
            p.vx += (dx / dist) * force;
            p.vy += (dy / dist) * force;
          }
        }

        // Dampen back toward base velocity
        p.vx += (p.baseVx - p.vx) * 0.02;
        p.vy += (p.baseVy - p.vy) * 0.02;

        // Clamp speed
        const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);
        if (speed > 3) {
          p.vx = (p.vx / speed) * 3;
          p.vy = (p.vy / speed) * 3;
        }

        p.x += p.vx;
        p.y += p.vy;

        // Wrap edges
        if (p.x < -10) p.x = width + 10;
        if (p.x > width + 10) p.x = -10;
        if (p.y < -10) p.y = height + 10;
        if (p.y > height + 10) p.y = -10;
      }

      // Draw connections — brighter near mouse
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < CONNECTION_DIST) {
            const midX = (particles[i].x + particles[j].x) / 2;
            const midY = (particles[i].y + particles[j].y) / 2;
            const mouseDx = midX - mouseX;
            const mouseDy = midY - mouseY;
            const mouseDist = Math.sqrt(mouseDx * mouseDx + mouseDy * mouseDy);
            const mouseBoost = mouseActive ? Math.max(0, 1 - mouseDist / MOUSE_RADIUS) : 0;

            const baseOpacity = (1 - dist / CONNECTION_DIST) * CONN_BASE_OPACITY;
            const opacity = baseOpacity + mouseBoost * CONN_MOUSE_BOOST;
            const lineW = 0.6 + mouseBoost * 1.2;

            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(96, 165, 250, ${opacity})`;
            ctx.lineWidth = lineW;
            ctx.stroke();
          }
        }
      }

      // Draw mouse-to-particle connections
      if (mouseActive) {
        for (const p of particles) {
          const dx = p.x - mouseX;
          const dy = p.y - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < MOUSE_RADIUS * 0.7) {
            const opacity = (1 - dist / (MOUSE_RADIUS * 0.7)) * 0.2;
            ctx.beginPath();
            ctx.moveTo(mouseX, mouseY);
            ctx.lineTo(p.x, p.y);
            ctx.strokeStyle = `rgba(147, 197, 253, ${opacity})`;
            ctx.lineWidth = 0.4;
            ctx.stroke();
          }
        }
      }

      // Draw particles — glow boost near mouse
      for (const p of particles) {
        const dx = p.x - mouseX;
        const dy = p.y - mouseY;
        const mouseDist = Math.sqrt(dx * dx + dy * dy);
        const mouseProximity = mouseActive ? Math.max(0, 1 - mouseDist / MOUSE_RADIUS) : 0;

        const alpha = p.alpha + mouseProximity * 0.45;
        const radius = p.r + mouseProximity * 2;

        // Glow halo near mouse
        if (mouseProximity > 0.2) {
          const haloR = radius * 3.5;
          const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, haloR);
          grad.addColorStop(0, `rgba(${p.color.r}, ${p.color.g}, ${p.color.b}, ${mouseProximity * 0.15})`);
          grad.addColorStop(1, `rgba(${p.color.r}, ${p.color.g}, ${p.color.b}, 0)`);
          ctx.beginPath();
          ctx.arc(p.x, p.y, haloR, 0, Math.PI * 2);
          ctx.fillStyle = grad;
          ctx.fill();
        }

        // Core dot
        ctx.beginPath();
        ctx.arc(p.x, p.y, radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${p.color.r}, ${p.color.g}, ${p.color.b}, ${alpha})`;
        ctx.fill();
      }

      animId = requestAnimationFrame(draw);
    }

    // Pause when off-screen for performance
    const observer = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) {
        if (!animId) draw();
      } else {
        if (animId) {
          cancelAnimationFrame(animId);
          animId = null;
        }
      }
    }, { threshold: 0 });

    resize();
    createParticles();
    observer.observe(canvas);

    window.addEventListener('resize', () => {
      const oldW = width, oldH = height;
      resize();
      // Scale existing particles to new dimensions instead of randomizing
      if (particles && oldW && oldH) {
        const sx = width / oldW, sy = height / oldH;
        for (const p of particles) {
          p.x *= sx;
          p.y *= sy;
        }
      } else {
        createParticles();
      }
    });
  })();
</script>
