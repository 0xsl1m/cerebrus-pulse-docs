<section class="landing-hero pt-24">
  <!-- CRT Scanline overlay -->
  <div class="hero-scanlines" aria-hidden="true"></div>

  <!-- WebGL Particle Canvas — lightweight ambient depth layer -->
  <canvas id="hero-particles" class="hero-particle-canvas" aria-hidden="true"></canvas>

  <!-- Ambient orbs for depth (parallax layers) -->
  <div class="orb orb-blue" data-parallax="slow"></div>
  <div class="orb orb-amber" data-parallax="slower"></div>
  <div class="orb orb-blue-secondary" data-parallax="medium"></div>

  <!-- Atmospheric background texture -->
  <div class="hero-bg-texture" aria-hidden="true">
    <picture>
      <source srcset="/images/hero-bg.webp" type="image/webp" />
      <img
        src="/images/hero-bg.jpg"
        alt=""
        class="hero-bg-img"
        loading="eager"
        decoding="async"
      />
    </picture>
  </div>

  <!-- 3D Electrified Brain -->
  <div class="brain-container" aria-hidden="true" data-parallax="brain">
    <div class="brain-glow"></div>
    <div class="brain-glow-amber"></div>
    <div class="brain-perspective">
      <svg
        class="brain-svg"
        viewBox="0 0 800 700"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
      >
        <defs>
          <!-- ====== NEON OUTLINE FILTERS ====== -->
          <!-- Blue neon: white-hot core + blue outer bloom -->
          <filter id="neon-blue" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur in="SourceGraphic" stdDeviation="2" result="blur1" />
            <feGaussianBlur in="SourceGraphic" stdDeviation="6" result="blur2" />
            <feGaussianBlur in="SourceGraphic" stdDeviation="12" result="blur3" />
            <feFlood flood-color="#60A5FA" flood-opacity="0.6" result="color1" />
            <feFlood flood-color="#3B82F6" flood-opacity="0.3" result="color2" />
            <feComposite in="color1" in2="blur2" operator="in" result="glow1" />
            <feComposite in="color2" in2="blur3" operator="in" result="glow2" />
            <feMerge>
              <feMergeNode in="glow2" />
              <feMergeNode in="glow1" />
              <feMergeNode in="blur1" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <!-- Amber neon: white-hot core + amber outer bloom -->
          <filter id="neon-amber" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur in="SourceGraphic" stdDeviation="2" result="blur1" />
            <feGaussianBlur in="SourceGraphic" stdDeviation="6" result="blur2" />
            <feGaussianBlur in="SourceGraphic" stdDeviation="12" result="blur3" />
            <feFlood flood-color="#FBBF24" flood-opacity="0.6" result="color1" />
            <feFlood flood-color="#F59E0B" flood-opacity="0.3" result="color2" />
            <feComposite in="color1" in2="blur2" operator="in" result="glow1" />
            <feComposite in="color2" in2="blur3" operator="in" result="glow2" />
            <feMerge>
              <feMergeNode in="glow2" />
              <feMergeNode in="glow1" />
              <feMergeNode in="blur1" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <!-- Stem neon: purple/violet bloom -->
          <filter id="neon-stem" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="blur1" />
            <feGaussianBlur in="SourceGraphic" stdDeviation="8" result="blur2" />
            <feFlood flood-color="#A78BFA" flood-opacity="0.5" result="color1" />
            <feComposite in="color1" in2="blur2" operator="in" result="glow1" />
            <feMerge>
              <feMergeNode in="glow1" />
              <feMergeNode in="blur1" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <!-- Blue glow filter for neural net -->
          <filter id="glow-blue" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="6" result="blur" />
            <feFlood flood-color="#3B82F6" flood-opacity="0.8" result="color" />
            <feComposite in="color" in2="blur" operator="in" result="shadow" />
            <feMerge>
              <feMergeNode in="shadow" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <!-- Amber glow filter for neural net -->
          <filter id="glow-amber" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="6" result="blur" />
            <feFlood flood-color="#F59E0B" flood-opacity="0.8" result="color" />
            <feComposite in="color" in2="blur" operator="in" result="shadow" />
            <feMerge>
              <feMergeNode in="shadow" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <!-- Intense glow for firing nodes -->
          <filter id="glow-node-blue" x="-100%" y="-100%" width="300%" height="300%">
            <feGaussianBlur stdDeviation="8" result="blur" />
            <feFlood flood-color="#60A5FA" flood-opacity="0.9" result="color" />
            <feComposite in="color" in2="blur" operator="in" result="shadow" />
            <feMerge>
              <feMergeNode in="shadow" />
              <feMergeNode in="shadow" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <filter id="glow-node-amber" x="-100%" y="-100%" width="300%" height="300%">
            <feGaussianBlur stdDeviation="8" result="blur" />
            <feFlood flood-color="#FBBF24" flood-opacity="0.9" result="color" />
            <feComposite in="color" in2="blur" operator="in" result="shadow" />
            <feMerge>
              <feMergeNode in="shadow" />
              <feMergeNode in="shadow" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <!-- Energy core glow filter -->
          <filter id="glow-core" x="-100%" y="-100%" width="300%" height="300%">
            <feGaussianBlur stdDeviation="10" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <!-- Bridge arc glow (dual color) -->
          <filter id="glow-bridge" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="3" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>

          <!-- Gradient for bridge arcs -->
          <linearGradient id="bridge-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#3B82F6" />
            <stop offset="50%" stop-color="#A78BFA" />
            <stop offset="100%" stop-color="#F59E0B" />
          </linearGradient>

          <linearGradient id="bridge-gradient-2" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#60A5FA" />
            <stop offset="50%" stop-color="#C084FC" />
            <stop offset="100%" stop-color="#FBBF24" />
          </linearGradient>

          <!-- Stem gradient (vertical blue → purple → amber) -->
          <linearGradient id="stem-gradient" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#A78BFA" />
            <stop offset="40%" stop-color="#C084FC" />
            <stop offset="100%" stop-color="#818CF8" />
          </linearGradient>
        </defs>

        <!-- ============================================ -->
        <!-- HEXAGONAL GRID — faint HUD backdrop          -->
        <!-- ============================================ -->
        <defs>
          <pattern id="hex-grid" width="30" height="52" patternUnits="userSpaceOnUse" patternTransform="translate(400,310)">
            <path d="M15 0 L30 8.66 L30 26 L15 34.64 L0 26 L0 8.66 Z" fill="none" stroke="rgba(59,130,246,0.06)" stroke-width="0.5"/>
            <path d="M15 17.32 L30 25.98 L30 43.3 L15 51.96 L0 43.3 L0 25.98 Z" fill="none" stroke="rgba(59,130,246,0.06)" stroke-width="0.5"/>
          </pattern>
          <radialGradient id="hex-mask-grad" cx="50%" cy="44%" r="40%">
            <stop offset="0%" stop-color="white" stop-opacity="1"/>
            <stop offset="70%" stop-color="white" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="white" stop-opacity="0"/>
          </radialGradient>
          <mask id="hex-fade-mask">
            <rect width="800" height="700" fill="url(#hex-mask-grad)"/>
          </mask>
        </defs>
        <rect class="brain-hex-grid" x="0" y="0" width="800" height="700" fill="url(#hex-grid)" mask="url(#hex-fade-mask)" opacity="0.8"/>

        <!-- ============================================ -->
        <!-- SONAR PULSE WAVES — radiating from center    -->
        <!-- ============================================ -->
        <g class="sonar-waves">
          <circle class="sonar-ring sonar-ring-1" cx="400" cy="310" r="20" fill="none" stroke="url(#bridge-gradient)" stroke-width="1.5" opacity="0"/>
          <circle class="sonar-ring sonar-ring-2" cx="400" cy="310" r="20" fill="none" stroke="url(#bridge-gradient-2)" stroke-width="1.5" opacity="0"/>
          <circle class="sonar-ring sonar-ring-3" cx="400" cy="310" r="20" fill="none" stroke="url(#bridge-gradient)" stroke-width="1" opacity="0"/>
        </g>

        <!-- ============================================ -->
