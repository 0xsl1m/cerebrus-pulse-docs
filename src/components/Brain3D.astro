<canvas id="brain-3d-canvas" class="brain-3d-canvas" aria-hidden="true"></canvas>

<script>
  import * as THREE from 'three';
  // Bloom via CSS filter instead of EffectComposer (which kills alpha transparency)

  // ============================================================
  // CEREBRUS PULSE — 3D Neural Brain Visualization
  // Sci-fi holographic wireframe brain with electric neural firing
  // ============================================================

  function initBrain3D() {
    // Prevent double-init
    if ((window as any).__brain3dInit) return;
    (window as any).__brain3dInit = true;

    // Respect prefers-reduced-motion
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const canvas = document.querySelector('.brain-3d-canvas') as HTMLCanvasElement;
    if (!canvas) {
      console.warn('[Brain3D] Canvas not found');
      return;
    }
    console.log('[Brain3D] Canvas found, parent size:', canvas.parentElement?.clientWidth, canvas.parentElement?.clientHeight);

    // ---- Colors ----
    const BLUE = new THREE.Color(0x3B82F6);
    const BLUE_LIGHT = new THREE.Color(0x60A5FA);
    const AMBER = new THREE.Color(0xF59E0B);
    const AMBER_LIGHT = new THREE.Color(0xFBBF24);
    const VIOLET = new THREE.Color(0xA78BFA);
    const VIOLET_LIGHT = new THREE.Color(0xC084FC);
    const WHITE = new THREE.Color(0xE0F2FE);

    // ---- Renderer ----
    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
      premultipliedAlpha: false,
      powerPreference: 'high-performance',
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);
    renderer.autoClear = true;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.0;
    console.log('[Brain3D] Renderer created, WebGL context:', !!renderer.getContext());

    // ---- Scene & Camera ----
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
    camera.position.set(0, 0.3, 5.5);
    camera.lookAt(0, -0.1, 0);

    // ============================================================
    // BRAIN GEOMETRY — Procedural parametric brain shape
    // Uses deformed icosphere split into hemispheres
    // ============================================================

    function createBrainGeometry(): {
      leftVerts: THREE.Vector3[];
      rightVerts: THREE.Vector3[];
      leftEdges: [number, number][];
      rightEdges: [number, number][];
      bridgeEdges: [THREE.Vector3, THREE.Vector3][];
      stemVerts: THREE.Vector3[];
      stemEdges: [number, number][];
    } {
      // Create an icosahedron and subdivide for brain mesh
      const icoGeo = new THREE.IcosahedronGeometry(1.6, 4);
      const positions = icoGeo.getAttribute('position');
      const index = icoGeo.getIndex();

      // Collect unique vertices
      const vertMap = new Map<string, number>();
      const allVerts: THREE.Vector3[] = [];

      function addVert(v: THREE.Vector3): number {
        const key = `${v.x.toFixed(4)},${v.y.toFixed(4)},${v.z.toFixed(4)}`;
        if (vertMap.has(key)) return vertMap.get(key)!;
        const idx = allVerts.length;
        vertMap.set(key, idx);
        allVerts.push(v.clone());
        return idx;
      }

      // Collect edges from triangles
      const edgeSet = new Set<string>();
      const edges: [number, number][] = [];

      function addEdge(a: number, b: number) {
        const key = a < b ? `${a}-${b}` : `${b}-${a}`;
        if (!edgeSet.has(key)) {
          edgeSet.add(key);
          edges.push([a, b]);
        }
      }

      if (index) {
        // Indexed geometry
        for (let i = 0; i < index.count; i += 3) {
          const idxA = index.getX(i);
          const idxB = index.getX(i + 1);
          const idxC = index.getX(i + 2);
          const vA = new THREE.Vector3().fromBufferAttribute(positions, idxA);
          const vB = new THREE.Vector3().fromBufferAttribute(positions, idxB);
          const vC = new THREE.Vector3().fromBufferAttribute(positions, idxC);
          const a = addVert(vA);
          const b = addVert(vB);
          const c = addVert(vC);
          addEdge(a, b);
          addEdge(b, c);
          addEdge(a, c);
        }
      } else {
        // Non-indexed geometry — every 3 positions is a triangle
        for (let i = 0; i < positions.count; i += 3) {
          const vA = new THREE.Vector3().fromBufferAttribute(positions, i);
          const vB = new THREE.Vector3().fromBufferAttribute(positions, i + 1);
          const vC = new THREE.Vector3().fromBufferAttribute(positions, i + 2);
          const a = addVert(vA);
          const b = addVert(vB);
          const c = addVert(vC);
          addEdge(a, b);
          addEdge(b, c);
          addEdge(a, c);
        }
      }
      console.log('[Brain3D] Geometry: indexed=' + !!index, 'verts=' + allVerts.length, 'edges=' + edges.length);

      // ---- Deform sphere into brain shape ----
      for (const v of allVerts) {
        // Normalize to sphere first
        const len = v.length();
        const nx = v.x / len;
        const ny = v.y / len;
        const nz = v.z / len;

        // Brain proportions: wider, slightly squashed top-bottom, elongated front-back
        let sx = 1.15;  // wider
        let sy = 0.88;  // shorter vertically
        let sz = 1.0;   // normal depth

        // Hemisphere separation — push each side outward slightly
        if (nx > 0.05) sx *= 1.05;
        else if (nx < -0.05) sx *= 1.05;

        // Interhemispheric fissure — pinch at midline top
        const midlinePinch = Math.exp(-nx * nx * 20) * 0.15;
        if (ny > 0) {
          sy -= midlinePinch * ny;
        }

        // Frontal lobe bulge (front, slightly higher)
        const frontalBulge = Math.max(0, nz) * Math.max(0, ny + 0.3) * 0.2;
        sz += frontalBulge;

        // Temporal lobe bulge (sides, lower)
        const temporalBulge = Math.abs(nx) * Math.max(0, -ny - 0.1) * 0.18;
        sx += temporalBulge;

        // Occipital bulge (rear, slightly lower)
        const occipitalBulge = Math.max(0, -nz - 0.2) * Math.max(0, -ny) * 0.15;
        sz += occipitalBulge;

        // Flatten bottom for brain stem connection
        if (ny < -0.7) {
          sy *= 0.7 + (ny + 1) * 0.3;
        }

        // Cortical folds — high-frequency noise displacement
        const fold1 = Math.sin(nx * 12 + ny * 8) * Math.sin(ny * 15 + nz * 10) * 0.06;
        const fold2 = Math.sin(nx * 20 + nz * 14) * Math.sin(ny * 18) * 0.03;
        const foldDisp = (fold1 + fold2) * len;

        v.x = nx * len * sx + nx * foldDisp;
        v.y = ny * len * sy + ny * foldDisp;
        v.z = nz * len * sz + nz * foldDisp;

        // Add jagged edge — high-frequency vertex displacement for "electric" look
        const jag = (Math.sin(v.x * 30 + v.y * 25) * Math.cos(v.z * 20 + v.x * 15)) * 0.025;
        v.x += jag;
        v.y += jag * 0.7;
        v.z += jag * 0.5;
      }

      // Split into hemispheres
      const leftVerts: THREE.Vector3[] = [];
      const rightVerts: THREE.Vector3[] = [];
      const leftIdx: number[] = [];
      const rightIdx: number[] = [];
      const oldToLeft = new Map<number, number>();
      const oldToRight = new Map<number, number>();

      for (let i = 0; i < allVerts.length; i++) {
        if (allVerts[i].x <= 0.08) {
          oldToLeft.set(i, leftVerts.length);
          leftVerts.push(allVerts[i]);
          leftIdx.push(i);
        }
        if (allVerts[i].x >= -0.08) {
          oldToRight.set(i, rightVerts.length);
          rightVerts.push(allVerts[i]);
          rightIdx.push(i);
        }
      }

      const leftEdges: [number, number][] = [];
      const rightEdges: [number, number][] = [];

      for (const [a, b] of edges) {
        if (oldToLeft.has(a) && oldToLeft.has(b)) {
          leftEdges.push([oldToLeft.get(a)!, oldToLeft.get(b)!]);
        }
        if (oldToRight.has(a) && oldToRight.has(b)) {
          rightEdges.push([oldToRight.get(a)!, oldToRight.get(b)!]);
        }
      }

      // ---- Bridge connections (corpus callosum) ----
      const bridgeEdges: [THREE.Vector3, THREE.Vector3][] = [];
      const bridgeLeftCandidates = leftVerts.filter(v => v.x > -0.3 && v.x < 0.1 && v.y > -0.5);
      const bridgeRightCandidates = rightVerts.filter(v => v.x < 0.3 && v.x > -0.1 && v.y > -0.5);

      // Pick closest cross-hemisphere pairs
      for (let i = 0; i < Math.min(bridgeLeftCandidates.length, 20); i++) {
        const lv = bridgeLeftCandidates[i];
        let bestDist = Infinity;
        let bestRv: THREE.Vector3 | null = null;
        for (const rv of bridgeRightCandidates) {
          const d = lv.distanceTo(rv);
          if (d > 0.05 && d < 0.6 && d < bestDist) {
            bestDist = d;
            bestRv = rv;
          }
        }
        if (bestRv) {
          bridgeEdges.push([lv, bestRv]);
        }
      }

      // ---- Brain stem ----
      const stemVerts: THREE.Vector3[] = [];
      const stemEdges: [number, number][] = [];

      // Generate stem as a tapered cylinder of vertices going downward
      const stemLevels = 8;
      const stemRingsPerLevel = 6;
      for (let level = 0; level < stemLevels; level++) {
        const t = level / (stemLevels - 1);
        const y = -1.25 - t * 1.2;
        // Medulla bulge at top, taper at bottom
        let radius = 0.2;
        if (t < 0.2) radius = 0.25 + (0.2 - t) * 0.5; // medulla bulge
        else radius = 0.22 - t * 0.12;

        for (let r = 0; r < stemRingsPerLevel; r++) {
          const angle = (r / stemRingsPerLevel) * Math.PI * 2;
          const jitter = (Math.sin(level * 7 + r * 13) * 0.02);
          stemVerts.push(new THREE.Vector3(
            Math.cos(angle) * radius + jitter,
            y + (Math.sin(angle + level) * 0.02),
            Math.sin(angle) * radius + jitter
          ));
        }

        // Ring edges
        const baseIdx = level * stemRingsPerLevel;
        for (let r = 0; r < stemRingsPerLevel; r++) {
          stemEdges.push([baseIdx + r, baseIdx + (r + 1) % stemRingsPerLevel]);
        }

        // Connect to previous level
        if (level > 0) {
          const prevBase = (level - 1) * stemRingsPerLevel;
          for (let r = 0; r < stemRingsPerLevel; r++) {
            stemEdges.push([prevBase + r, baseIdx + r]);
            // Cross-bracing for structural look
            if (r % 2 === 0) {
              stemEdges.push([prevBase + r, baseIdx + (r + 1) % stemRingsPerLevel]);
            }
          }
        }
      }

      // Add nerve fiber lines descending from stem
      for (let fiber = 0; fiber < 4; fiber++) {
        const angle = (fiber / 4) * Math.PI * 2 + Math.PI / 4;
        const fiberVerts: number[] = [];
        for (let seg = 0; seg < 6; seg++) {
          const t = seg / 5;
          const y = -2.45 - t * 0.8;
          const spread = t * 0.3;
          const idx = stemVerts.length;
          stemVerts.push(new THREE.Vector3(
            Math.cos(angle) * (0.08 + spread) + Math.sin(seg * 5) * 0.02,
            y,
            Math.sin(angle) * (0.08 + spread) + Math.cos(seg * 7) * 0.02
          ));
          fiberVerts.push(idx);
          if (seg > 0) {
            stemEdges.push([fiberVerts[seg - 1], idx]);
          }
        }
        // Connect top of fiber to bottom stem ring
        const bottomRingBase = (stemLevels - 1) * stemRingsPerLevel;
        stemEdges.push([bottomRingBase + Math.floor(fiber * stemRingsPerLevel / 4) % stemRingsPerLevel, fiberVerts[0]]);
      }

      console.log('[Brain3D] Hemispheres: L=' + leftVerts.length + '/' + leftEdges.length + ' R=' + rightVerts.length + '/' + rightEdges.length + ' bridge=' + bridgeEdges.length + ' stem=' + stemVerts.length + '/' + stemEdges.length);

      icoGeo.dispose();
      return { leftVerts, rightVerts, leftEdges, rightEdges, bridgeEdges, stemVerts, stemEdges };
    }

    // ============================================================
    // BUILD SCENE
    // ============================================================

    const brain = createBrainGeometry();
    const brainGroup = new THREE.Group();
    scene.add(brainGroup);

    // Shift brain up slightly so it's centered higher in the canvas
    brainGroup.position.y = 0.35;

    // ---- Helper: create wireframe lines from verts + edges ----
    function createWireframe(
      verts: THREE.Vector3[],
      edges: [number, number][],
      color: THREE.Color,
      opacity: number
    ): THREE.LineSegments {
      const geo = new THREE.BufferGeometry();
      const posArr: number[] = [];
      for (const [a, b] of edges) {
        posArr.push(verts[a].x, verts[a].y, verts[a].z);
        posArr.push(verts[b].x, verts[b].y, verts[b].z);
      }
      geo.setAttribute('position', new THREE.Float32BufferAttribute(posArr, 3));
      const mat = new THREE.LineBasicMaterial({
        color,
        transparent: true,
        opacity,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
      });
      return new THREE.LineSegments(geo, mat);
    }

    // ---- Left hemisphere wireframe (blue) ----
    const leftWire = createWireframe(brain.leftVerts, brain.leftEdges, BLUE, 0.35);
    brainGroup.add(leftWire);

    // Brighter outline edges for left
    const leftOuterEdges = brain.leftEdges.filter(([a, b]) => {
      const va = brain.leftVerts[a];
      const vb = brain.leftVerts[b];
      const avgLen = (va.length() + vb.length()) / 2;
      return avgLen > 1.45;
    });
    const leftOutline = createWireframe(brain.leftVerts, leftOuterEdges, BLUE_LIGHT, 0.6);
    brainGroup.add(leftOutline);

    // ---- Right hemisphere wireframe (amber) ----
    const rightWire = createWireframe(brain.rightVerts, brain.rightEdges, AMBER, 0.35);
    brainGroup.add(rightWire);

    const rightOuterEdges = brain.rightEdges.filter(([a, b]) => {
      const va = brain.rightVerts[a];
      const vb = brain.rightVerts[b];
      const avgLen = (va.length() + vb.length()) / 2;
      return avgLen > 1.45;
    });
    const rightOutline = createWireframe(brain.rightVerts, rightOuterEdges, AMBER_LIGHT, 0.6);
    brainGroup.add(rightOutline);

    // ---- Bridge connections (violet) ----
    const bridgeGeo = new THREE.BufferGeometry();
    const bridgePos: number[] = [];
    for (const [a, b] of brain.bridgeEdges) {
      bridgePos.push(a.x, a.y, a.z);
      bridgePos.push(b.x, b.y, b.z);
    }
    bridgeGeo.setAttribute('position', new THREE.Float32BufferAttribute(bridgePos, 3));
    const bridgeMat = new THREE.LineBasicMaterial({
      color: VIOLET,
      transparent: true,
      opacity: 0.45,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    const bridgeLines = new THREE.LineSegments(bridgeGeo, bridgeMat);
    brainGroup.add(bridgeLines);

    // ---- Brain stem (violet/purple) ----
    const stemWire = createWireframe(brain.stemVerts, brain.stemEdges, VIOLET, 0.4);
    brainGroup.add(stemWire);

    // ============================================================
    // NEURAL NODES — Instanced spheres at vertices
    // ============================================================

    const NODE_COUNT_LEFT = Math.min(brain.leftVerts.length, 120);
    const NODE_COUNT_RIGHT = Math.min(brain.rightVerts.length, 120);
    const NODE_COUNT_STEM = Math.min(brain.stemVerts.length, 30);

    // Pick a subset of verts evenly distributed
    function pickSubset(verts: THREE.Vector3[], count: number): THREE.Vector3[] {
      if (verts.length <= count) return verts.slice();
      const step = verts.length / count;
      const result: THREE.Vector3[] = [];
      for (let i = 0; i < count; i++) {
        result.push(verts[Math.floor(i * step)]);
      }
      return result;
    }

    const nodeGeo = new THREE.SphereGeometry(0.015, 5, 3);

    function createNodes(
      verts: THREE.Vector3[],
      count: number,
      color: THREE.Color
    ): { mesh: THREE.InstancedMesh; positions: THREE.Vector3[]; phases: number[] } {
      const subset = pickSubset(verts, count);
      const mat = new THREE.MeshBasicMaterial({
        color,
        transparent: true,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
      });
      const mesh = new THREE.InstancedMesh(nodeGeo, mat, subset.length);
      const dummy = new THREE.Object3D();
      const phases: number[] = [];

      for (let i = 0; i < subset.length; i++) {
        dummy.position.copy(subset[i]);
        dummy.scale.setScalar(0.5 + Math.random() * 0.4);
        dummy.updateMatrix();
        mesh.setMatrixAt(i, dummy.matrix);
        phases.push(Math.random() * Math.PI * 2);
      }
      mesh.instanceMatrix.needsUpdate = true;
      return { mesh, positions: subset, phases };
    }

    const leftNodes = createNodes(brain.leftVerts, NODE_COUNT_LEFT, BLUE_LIGHT);
    brainGroup.add(leftNodes.mesh);

    const rightNodes = createNodes(brain.rightVerts, NODE_COUNT_RIGHT, AMBER_LIGHT);
    brainGroup.add(rightNodes.mesh);

    const stemNodes = createNodes(brain.stemVerts, NODE_COUNT_STEM, VIOLET_LIGHT);
    brainGroup.add(stemNodes.mesh);

    // ============================================================
    // NEURAL PULSES — Electric arcs traveling along edges
    // ============================================================

    interface Pulse {
      startPos: THREE.Vector3;
      endPos: THREE.Vector3;
      progress: number;
      speed: number;
      color: THREE.Color;
    }

    const pulses: Pulse[] = [];
    const MAX_PULSES = 30;
    const pulseGeo = new THREE.SphereGeometry(0.018, 4, 3);

    function spawnPulse() {
      if (pulses.length >= MAX_PULSES) return;

      const roll = Math.random();
      let startPos: THREE.Vector3;
      let endPos: THREE.Vector3;
      let color: THREE.Color;

      if (roll < 0.35 && brain.leftEdges.length > 0) {
        // Left hemisphere pulse
        const edge = brain.leftEdges[Math.floor(Math.random() * brain.leftEdges.length)];
        startPos = brain.leftVerts[edge[0]];
        endPos = brain.leftVerts[edge[1]];
        color = BLUE_LIGHT;
      } else if (roll < 0.7 && brain.rightEdges.length > 0) {
        // Right hemisphere pulse
        const edge = brain.rightEdges[Math.floor(Math.random() * brain.rightEdges.length)];
        startPos = brain.rightVerts[edge[0]];
        endPos = brain.rightVerts[edge[1]];
        color = AMBER_LIGHT;
      } else if (roll < 0.85 && brain.bridgeEdges.length > 0) {
        // Bridge pulse
        const bridge = brain.bridgeEdges[Math.floor(Math.random() * brain.bridgeEdges.length)];
        startPos = bridge[0];
        endPos = bridge[1];
        color = VIOLET_LIGHT;
      } else if (brain.stemEdges.length > 0) {
        // Stem pulse
        const edge = brain.stemEdges[Math.floor(Math.random() * brain.stemEdges.length)];
        startPos = brain.stemVerts[edge[0]];
        endPos = brain.stemVerts[edge[1]];
        color = VIOLET;
      } else {
        return;
      }

      pulses.push({
        startPos,
        endPos,
        progress: 0,
        speed: 0.6 + Math.random() * 1.2,
        color,
      });
    }

    // Create pulse meshes pool
    const pulseMeshes: THREE.Mesh[] = [];
    for (let i = 0; i < MAX_PULSES; i++) {
      const mat = new THREE.MeshBasicMaterial({
        color: 0xffffff,
        transparent: true,
        opacity: 0,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
      });
      const mesh = new THREE.Mesh(pulseGeo, mat);
      mesh.visible = false;
      brainGroup.add(mesh);
      pulseMeshes.push(mesh);
    }

    // ============================================================
    // BACKGROUND PARTICLE FIELD — depth particles around brain
    // ============================================================

    const PARTICLE_COUNT = 300;
    const particlePositions = new Float32Array(PARTICLE_COUNT * 3);
    const particleColors = new Float32Array(PARTICLE_COUNT * 3);
    const particleSpeeds: number[] = [];

    for (let i = 0; i < PARTICLE_COUNT; i++) {
      const i3 = i * 3;
      // Distribute in a large sphere around brain
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      const r = 3 + Math.random() * 5;
      particlePositions[i3] = r * Math.sin(phi) * Math.cos(theta);
      particlePositions[i3 + 1] = r * Math.sin(phi) * Math.sin(theta);
      particlePositions[i3 + 2] = r * Math.cos(phi);

      const isAmber = Math.random() > 0.6;
      if (isAmber) {
        particleColors[i3] = 0.96;
        particleColors[i3 + 1] = 0.62;
        particleColors[i3 + 2] = 0.04;
      } else {
        particleColors[i3] = 0.23;
        particleColors[i3 + 1] = 0.51;
        particleColors[i3 + 2] = 0.96;
      }
      particleSpeeds.push(0.1 + Math.random() * 0.3);
    }

    const particleGeo = new THREE.BufferGeometry();
    particleGeo.setAttribute('position', new THREE.Float32BufferAttribute(particlePositions, 3));
    particleGeo.setAttribute('color', new THREE.Float32BufferAttribute(particleColors, 3));

    const particleMat = new THREE.PointsMaterial({
      size: 0.02,
      vertexColors: true,
      transparent: true,
      opacity: 0.3,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      sizeAttenuation: true,
    });
    const particleField = new THREE.Points(particleGeo, particleMat);
    scene.add(particleField);

    // ============================================================
    // RESIZE HANDLER
    // ============================================================

    function resize() {
      const parent = canvas.parentElement;
      if (!parent) return;
      const w = parent.clientWidth || 700;
      const h = parent.clientHeight || 650;
      if (w < 1 || h < 1) return;

      canvas.width = w * Math.min(window.devicePixelRatio, 2);
      canvas.height = h * Math.min(window.devicePixelRatio, 2);
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';

      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h, false);
    }

    resize();
    console.log('[Brain3D] Initial resize done, canvas size:', canvas.width, canvas.height);
    window.addEventListener('resize', resize);
    // Retry resize after a tick in case layout wasn't ready
    setTimeout(() => { resize(); console.log('[Brain3D] Deferred resize, canvas:', canvas.width, canvas.height); }, 100);

    // ============================================================
    // ANIMATION LOOP
    // ============================================================

    let animId: number | null = null;
    let lastSpawnTime = 0;
    const clock = new THREE.Clock();

    function animate() {
      animId = requestAnimationFrame(animate);

      const elapsed = clock.getElapsedTime();

      if (reducedMotion) {
        // Static render — single frame, no animation
        renderer.render(scene, camera);
        if (animId) cancelAnimationFrame(animId);
        animId = null;
        return;
      }

      // ---- Gentle brain rotation ----
      brainGroup.rotation.y = Math.sin(elapsed * 0.15) * 0.25;
      brainGroup.rotation.x = Math.sin(elapsed * 0.1) * 0.05 - 0.05;
      brainGroup.rotation.z = Math.sin(elapsed * 0.08) * 0.03;

      // ---- Node firing animation ----
      const dummy = new THREE.Object3D();
      const fireNodes = (nodes: typeof leftNodes, baseScale: number) => {
        for (let i = 0; i < nodes.positions.length; i++) {
          const phase = nodes.phases[i];
          const fireIntensity = Math.pow(Math.max(0, Math.sin(elapsed * 1.5 + phase)), 4);
          const scale = baseScale * (0.4 + fireIntensity * 1.2);
          dummy.position.copy(nodes.positions[i]);
          dummy.scale.setScalar(scale);
          dummy.updateMatrix();
          nodes.mesh.setMatrixAt(i, dummy.matrix);
        }
        nodes.mesh.instanceMatrix.needsUpdate = true;
      };

      fireNodes(leftNodes, 0.8);
      fireNodes(rightNodes, 0.8);
      fireNodes(stemNodes, 0.6);

      // ---- Spawn pulses ----
      if (elapsed - lastSpawnTime > 0.08) {
        spawnPulse();
        lastSpawnTime = elapsed;
      }

      // ---- Update pulses ----
      for (let i = pulses.length - 1; i >= 0; i--) {
        const p = pulses[i];
        p.progress += p.speed * 0.016;

        if (p.progress >= 1) {
          pulses.splice(i, 1);
          pulseMeshes[i].visible = false;
          continue;
        }

        if (i < pulseMeshes.length) {
          const mesh = pulseMeshes[i];
          mesh.visible = true;
          mesh.position.lerpVectors(p.startPos, p.endPos, p.progress);

          const mat = mesh.material as THREE.MeshBasicMaterial;
          mat.color.copy(p.color);
          // Fade in-out
          const fade = Math.sin(p.progress * Math.PI);
          mat.opacity = fade * 0.9;
          mesh.scale.setScalar(0.4 + fade * 0.5);
        }
      }

      // Hide unused pulse meshes
      for (let i = pulses.length; i < pulseMeshes.length; i++) {
        pulseMeshes[i].visible = false;
      }

      // ---- Animate wireframe opacity (subtle breathing) ----
      const breathe = 0.3 + Math.sin(elapsed * 0.5) * 0.08;
      (leftWire.material as THREE.LineBasicMaterial).opacity = breathe;
      (rightWire.material as THREE.LineBasicMaterial).opacity = breathe;

      // ---- Rotate particle field ----
      particleField.rotation.y = elapsed * 0.02;
      particleField.rotation.x = Math.sin(elapsed * 0.05) * 0.1;

      // ---- Render ----
      renderer.render(scene, camera);
    }

    // ---- Start animation immediately ----
    animate();

    // ---- IntersectionObserver: pause when off-screen ----
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          if (!animId) {
            clock.start();
            animate();
          }
        } else {
          if (animId) {
            cancelAnimationFrame(animId);
            animId = null;
            clock.stop();
          }
        }
      },
      { threshold: 0, rootMargin: '200px' }
    );
    observer.observe(canvas);

    // ---- Cleanup on page navigation (Astro) ----
    document.addEventListener('astro:before-swap', () => {
      if (animId) cancelAnimationFrame(animId);
      observer.disconnect();
      renderer.dispose();
    });
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBrain3D);
  } else {
    initBrain3D();
  }
  // Also handle Astro page transitions
  document.addEventListener('astro:page-load', initBrain3D);
</script>

<style>
  .brain-3d-canvas {
    width: 100% !important;
    height: 100% !important;
    display: block;
    opacity: 0.7;
    filter: brightness(1.1) contrast(1.1);
  }
</style>
