---
// Interactive API demo — fetches live data from the free /demo endpoint
const sampleCoins = ['BTC', 'ETH', 'SOL', 'DOGE', 'XRP', 'ADA', 'AVAX', 'LINK'];
---

<div class="section-divider"></div>
<section class="landing-section landing-section-alt" id="demo">
  <div class="mx-auto max-w-5xl">
    <h2 class="mb-4 text-center text-3xl font-bold md:text-4xl text-[#E8ECF4]" data-reveal="slide-up">
      <span class="gradient-text">Try It Live</span>
    </h2>
    <p class="mb-8 sm:mb-12 text-center text-[#94A3B8] text-base sm:text-lg" data-reveal="slide-up">
      Live data from the free demo endpoint. No wallet needed.
    </p>

    <div class="mx-auto max-w-3xl" data-reveal="slide-up">
      <!-- Coin selector -->
      <div class="mb-4 flex flex-wrap items-center gap-2">
        <span class="text-xs text-[#64748B] font-mono mr-1">SELECT COIN:</span>
        {sampleCoins.map((coin, i) => (
          <button
            class={`demo-coin-btn ${i === 0 ? 'demo-coin-active' : ''}`}
            data-coin={coin}
          >
            {coin}
          </button>
        ))}
        <button class="demo-run-btn ml-auto" id="demo-run-btn">
          Run
        </button>
      </div>

      <!-- Request display -->
      <div class="code-block-wrapper">
        <div class="flex items-center justify-between border-b border-[#1E293B] px-4 py-2.5">
          <div class="flex items-center gap-2">
            <div class="h-3 w-3 rounded-full" style="background: rgba(239, 68, 68, 0.6);"></div>
            <div class="h-3 w-3 rounded-full" style="background: rgba(245, 158, 11, 0.6);"></div>
            <div class="h-3 w-3 rounded-full" style="background: rgba(34, 197, 94, 0.6);"></div>
            <span class="ml-2 text-xs text-[#64748B] font-mono" id="demo-status">click Run to fetch live data</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="price-badge" style="font-size: 0.75rem; padding: 0.125rem 0.5rem; background: rgba(34, 197, 94, 0.15); border-color: rgba(34, 197, 94, 0.3); color: #22C55E;">FREE</span>
          </div>
        </div>

        <!-- Request line -->
        <div class="border-b px-4 py-2 text-xs font-mono" style="border-color: rgba(30, 41, 59, 0.5);">
          <span class="text-[#22C55E]">GET</span>
          <span class="text-[#94A3B8]"> https://api.cerebruspulse.xyz/demo/</span><span class="text-[#FBBF24] demo-coin-display">BTC</span>
        </div>

        <!-- Response body -->
        <pre class="p-4 text-xs sm:text-sm leading-relaxed overflow-x-auto overflow-y-auto" style="max-height: 400px;" id="demo-response"><code class="text-[#CBD5E1]" id="demo-response-code">// Select a coin and click Run to see live analysis data</code></pre>
      </div>

      <!-- Bottom CTA -->
      <div class="mt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-[#64748B]">
          Demo returns <span class="text-[#60A5FA]">1h + 4h timeframes</span>. Paid endpoints unlock <span class="text-[#FBBF24]">all 6 timeframes</span> and <span class="text-[#22C55E]">higher rate limits</span>.
        </p>
        <a href="/api/pulse" class="btn-primary whitespace-nowrap" style="font-size: 0.875rem; padding: 0.5rem 1rem;">
          Full API Docs
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    const buttons = document.querySelectorAll('.demo-coin-btn');
    const displays = document.querySelectorAll('.demo-coin-display');
    const runBtn = document.getElementById('demo-run-btn');
    const responseCode = document.getElementById('demo-response-code');
    const status = document.getElementById('demo-status');
    let selectedCoin = 'BTC';
    let loading = false;

    function syntaxHighlight(json) {
      const str = JSON.stringify(json, null, 2);
      return str.replace(/("(?:\\u[\da-fA-F]{4}|\\[^u]|[^\\"])*")(\s*:)?|(\b(?:true|false|null)\b)|(-?\d+(?:\.\d*)?(?:[eE][+-]?\d+)?)/g,
        function (match, key, colon, bool, num) {
          if (key && colon) return `<span class="text-[#93C5FD]">${key}</span>:`;
          if (key) return `<span class="text-[#FBBF24]">${key}</span>`;
          if (bool) return `<span class="text-[#F472B6]">${match}</span>`;
          if (num) return `<span class="text-[#60A5FA]">${match}</span>`;
          return match;
        }
      );
    }

    async function fetchDemo() {
      if (loading) return;
      loading = true;
      runBtn.textContent = '...';
      runBtn.disabled = true;
      status.textContent = 'fetching...';
      responseCode.textContent = '// Loading...';

      try {
        const resp = await fetch(`https://api.cerebruspulse.xyz/demo/${selectedCoin}`);
        if (!resp.ok) {
          const err = await resp.text();
          responseCode.textContent = `// Error ${resp.status}: ${err}`;
          status.textContent = `error ${resp.status}`;
          return;
        }
        const data = await resp.json();
        responseCode.innerHTML = syntaxHighlight(data);
        status.textContent = `live response — ${new Date().toLocaleTimeString()}`;
      } catch (e) {
        responseCode.textContent = `// Network error: ${e.message}`;
        status.textContent = 'error';
      } finally {
        loading = false;
        runBtn.textContent = 'Run';
        runBtn.disabled = false;
      }
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('demo-coin-active'));
        btn.classList.add('demo-coin-active');
        selectedCoin = btn.dataset.coin;
        displays.forEach(d => d.textContent = selectedCoin);
      });
    });

    runBtn.addEventListener('click', fetchDemo);
  })();
</script>
