---
// Social proof: live metrics + ecosystem badges + integration options
---

<div class="section-divider"></div>
<section class="landing-section landing-section-dark relative overflow-hidden" id="metrics">
  <!-- Ambient gradient mesh -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/3 left-0 w-[600px] h-[400px] rounded-full blur-[160px]"
         style="background: rgba(59, 130, 246, 0.04);"></div>
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] rounded-full blur-[140px]"
         style="background: rgba(245, 158, 11, 0.03);"></div>
  </div>

  <div class="mx-auto max-w-5xl relative z-10">
    <h2 class="mb-4 text-center text-3xl font-bold md:text-4xl text-[#E8ECF4]" data-reveal="slide-up">
      <span class="gradient-text">Built for Speed</span>
    </h2>
    <p class="mb-10 sm:mb-14 text-center text-[#94A3B8] text-base sm:text-lg" data-reveal="slide-up">
      Real-time analysis, sub-second responses, enterprise-grade reliability.
    </p>

    <!-- Live Metrics Grid -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4 mb-14" data-reveal="stagger">
      <div class="metric-card">
        <div class="metric-value text-[#60A5FA]">&lt;200ms</div>
        <div class="metric-label">Avg Response</div>
        <div class="metric-sublabel">p95 under 500ms</div>
      </div>
      <div class="metric-card">
        <div class="metric-value text-[#22C55E]">99.9%</div>
        <div class="metric-label">Uptime</div>
        <div class="metric-sublabel">Monitored 24/7</div>
      </div>
      <div class="metric-card">
        <div class="metric-value text-[#FBBF24]">50+</div>
        <div class="metric-label">Perpetuals</div>
        <div class="metric-sublabel">Hyperliquid L1</div>
      </div>
      <div class="metric-card">
        <div class="metric-value gradient-text">13</div>
        <div class="metric-label">Paid Endpoints</div>
        <div class="metric-sublabel">6 timeframes per coin</div>
      </div>
    </div>

    <!-- Ecosystem Badges -->
    <div class="mb-10" data-reveal="slide-up">
      <h3 class="mb-6 text-center text-sm font-semibold uppercase tracking-wider text-[#64748B]">Ecosystem</h3>
      <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-6">
        <div class="ecosystem-badge">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#60A5FA]" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/>
          </svg>
          <span>x402 Protocol</span>
        </div>
        <div class="ecosystem-badge">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#FF69B4]" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.586 4.586a2 2 0 112.828 2.828l-3 3a2 2 0 01-2.828 0 1 1 0 00-1.414 1.414 4 4 0 005.656 0l3-3a4 4 0 00-5.656-5.656l-1.5 1.5a1 1 0 101.414 1.414l1.5-1.5zm-5 5a2 2 0 012.828 0 1 1 0 101.414-1.414 4 4 0 00-5.656 0l-3 3a4 4 0 105.656 5.656l1.5-1.5a1 1 0 10-1.414-1.414l-1.5 1.5a2 2 0 11-2.828-2.828l3-3z" clip-rule="evenodd"/>
          </svg>
          <span>Google A2A</span>
        </div>
        <div class="ecosystem-badge">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#FBBF24]" viewBox="0 0 20 20" fill="currentColor">
            <path d="M13 7H7v6h6V7z"/>
            <path fill-rule="evenodd" d="M7 2a1 1 0 012 0v1h2V2a1 1 0 112 0v1h2a2 2 0 012 2v2h1a1 1 0 110 2h-1v2h1a1 1 0 110 2h-1v2a2 2 0 01-2 2h-2v1a1 1 0 11-2 0v-1H9v1a1 1 0 11-2 0v-1H5a2 2 0 01-2-2v-2H2a1 1 0 110-2h1V9H2a1 1 0 010-2h1V5a2 2 0 012-2h2V2zM5 5h10v10H5V5z" clip-rule="evenodd"/>
          </svg>
          <span>Virtuals Protocol</span>
        </div>
        <div class="ecosystem-badge">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#60A5FA]" viewBox="0 0 20 20" fill="currentColor">
            <path d="M3 12v3c0 1.657 3.134 3 7 3s7-1.343 7-3v-3c0 1.657-3.134 3-7 3s-7-1.343-7-3z"/>
            <path d="M3 7v3c0 1.657 3.134 3 7 3s7-1.343 7-3V7c0 1.657-3.134 3-7 3S3 8.657 3 7z"/>
            <path d="M17 5c0 1.657-3.134 3-7 3S3 6.657 3 5s3.134-3 7-3 7 1.343 7 3z"/>
          </svg>
          <span>Base L2</span>
        </div>
        <div class="ecosystem-badge">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#9945FF]" viewBox="0 0 20 20" fill="currentColor">
            <path d="M3 12v3c0 1.657 3.134 3 7 3s7-1.343 7-3v-3c0 1.657-3.134 3-7 3s-7-1.343-7-3z"/>
            <path d="M3 7v3c0 1.657 3.134 3 7 3s7-1.343 7-3V7c0 1.657-3.134 3-7 3S3 8.657 3 7z"/>
            <path d="M17 5c0 1.657-3.134 3-7 3S3 6.657 3 5s3.134-3 7-3 7 1.343 7 3z"/>
          </svg>
          <span>Solana</span>
        </div>
        <div class="ecosystem-badge">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#22C55E]" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
          </svg>
          <span>USDC Payments</span>
        </div>
        <div class="ecosystem-badge">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#375BD2]" viewBox="0 0 37.9 43.6" fill="currentColor">
            <path d="M18.9 0l-4 2.3L4 8.6 0 10.9v21.8l4 2.3 10.9 6.3 4 2.3 4-2.3L33.8 34.9l4-2.3V10.9l-4-2.3L22.9 2.3 18.9 0zm0 5.5l10.2 5.9v11.8L18.9 29.1 8.7 23.2V11.4L18.9 5.5z"/>
          </svg>
          <span>Chainlink Data Feeds</span>
        </div>
        <div class="ecosystem-badge">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#94A3B8]" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
          <span>Hyperliquid</span>
        </div>
      </div>
    </div>

    <!-- Integration Options -->
    <div data-reveal="slide-up">
      <h3 class="mb-6 text-center text-sm font-semibold uppercase tracking-wider text-[#64748B]">Integrate Anywhere</h3>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <a href="https://github.com/0xsl1m/cerebrus-pulse-mcp" target="_blank" rel="noopener" class="integration-card group">
          <div class="text-sm font-semibold text-[#E8ECF4] group-hover:text-[#60A5FA] transition-colors">MCP Server</div>
          <div class="text-xs text-[#64748B]">Claude, Cursor, Windsurf</div>
        </a>
        <a href="/guides/python-sdk" class="integration-card group">
          <div class="text-sm font-semibold text-[#E8ECF4] group-hover:text-[#60A5FA] transition-colors">Python SDK</div>
          <div class="text-xs text-[#64748B]">pip install cerebrus-pulse</div>
        </a>
        <a href="/guides/typescript-sdk" class="integration-card group">
          <div class="text-sm font-semibold text-[#E8ECF4] group-hover:text-[#60A5FA] transition-colors">TypeScript Guide</div>
          <div class="text-xs text-[#64748B]">viem + x402</div>
        </a>
        <a href="https://github.com/0xsl1m/langchain-cerebrus-pulse" target="_blank" rel="noopener" class="integration-card group">
          <div class="text-sm font-semibold text-[#E8ECF4] group-hover:text-[#60A5FA] transition-colors">LangChain Tools</div>
          <div class="text-xs text-[#64748B]">AI agent framework</div>
        </a>
      </div>
    </div>
  </div>
</section>
