---
import Landing from '../layouts/Landing.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import PricingTable from '../components/PricingTable.astro';
import CoinGrid from '../components/CoinGrid.astro';
import LiveDemo from '../components/LiveDemo.astro';
import Metrics from '../components/Metrics.astro';
import Footer from '../components/Footer.astro';
---

<Landing
  title="Cerebrus Pulse — Real-time Crypto Intelligence"
  description="Cerebrus Pulse is a pay-per-query crypto intelligence API for 50+ Hyperliquid perpetuals across 6 timeframes. 15 x402 endpoints ($0.008-$0.06/query) with USDC payments on Base and Solana, A2A agent-to-agent protocol with Agent Card discovery, and ACP AI synthesis via Virtuals Protocol ($0.10-$2.00). No API keys or subscriptions required."
>
  <Hero />
  <HowItWorks />
  <PricingTable />
  <CoinGrid />
  <LiveDemo />
  <Metrics />

  <!-- CTA Banner -->
  <div class="section-divider"></div>
  <section class="landing-section landing-section-dark relative overflow-hidden cta-final">
    <!-- Trinity ambient glows -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[250px] rounded-full blur-[140px] cta-glow-blue"
           style="background: rgba(59, 130, 246, 0.08);">
      </div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[220px] rounded-full blur-[130px]"
           style="background: rgba(255, 20, 147, 0.06);">
      </div>
      <div class="absolute top-1/2 right-1/4 translate-x-1/2 -translate-y-1/2 w-[400px] h-[250px] rounded-full blur-[120px] cta-glow-amber"
           style="background: rgba(245, 158, 11, 0.06);">
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-3xl px-4 sm:px-6 text-center">
      <h2 class="mb-4 text-2xl sm:text-3xl font-bold md:text-4xl text-[#E8ECF4]" data-reveal="slide-up">
        <span class="gradient-text">Start Building</span>
      </h2>
      <p class="mb-6 sm:mb-8 text-base sm:text-lg text-[#94A3B8]" data-reveal="slide-up">
        Whether you're using <span class="text-[#60A5FA] font-medium">x402 micropayments</span>, connecting via <span class="text-[#FF69B4] font-medium">A2A protocol</span>, or deploying autonomous agents on <span class="text-[#FBBF24] font-medium">Virtuals</span> — get started in under 5 minutes.
      </p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row" data-reveal="slide-up">
        <a href="/quickstart" class="btn-primary">
          x402 Quickstart
        </a>
        <a href="/guides/a2a-agents" class="btn-secondary btn-a2a">
          A2A Protocol
        </a>
        <a href="/guides/acp-agents" class="btn-secondary btn-acp">
          ACP for Agents
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Landing>
