---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-900 text-white antialiased">
    <nav class="fixed top-0 z-50 w-full border-b border-gray-800 bg-gray-900/80 backdrop-blur-md">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-3 text-xl font-bold">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" class="h-8 w-8">
            <circle cx="24" cy="24" r="20" stroke="#0088cc" stroke-width="2.5" fill="none"/>
            <path d="M12 24h6l4-10 4 20 4-14 4 8h6" stroke="#0088cc" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <circle cx="24" cy="24" r="3" fill="#0088cc"/>
          </svg>
          <span>Cerebrus <span class="text-accent-200">Pulse</span></span>
        </a>
        <div class="flex items-center gap-6">
          <a href="#pricing" class="text-sm text-gray-300 hover:text-white transition-colors">Pricing</a>
          <a href="#coins" class="text-sm text-gray-300 hover:text-white transition-colors">Coins</a>
          <a href="/overview" class="rounded-lg bg-accent-600 px-4 py-2 text-sm font-semibold text-white hover:bg-accent-600/80 transition-colors">
            Documentation
          </a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>
