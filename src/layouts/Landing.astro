---
import '../styles/landing.css';
import StructuredData from '../components/StructuredData.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalURL = 'https://cerebruspulse.xyz';
const ogImage = canonicalURL + '/images/og-image.jpg';
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: Orbitron (hero) + Sora (display) + Outfit (body) + JetBrains Mono (code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;800;900&family=Sora:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- AI/LLM Discovery -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    <meta name="keywords" content="crypto API, cryptocurrency analysis, Hyperliquid, technical analysis, x402, micropayments, USDC, Base blockchain, ACP, Agent Commerce Protocol, Virtuals Protocol, RSI, EMA, Bollinger Bands, funding rates, market sentiment, AI agent, pay per query, no API key" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:site_name" content="Cerebrus Pulse" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <StructuredData
      title={title}
      description={description}
      url={canonicalURL}
    />
  </head>
  <body class="bg-[#0B0F1A] text-[#E8ECF4] antialiased">
    <nav class="nav-glass fixed top-0 z-50 w-full">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 sm:px-6 py-3 sm:py-4">
        <a href="/" class="flex items-center gap-2 sm:gap-3 text-base sm:text-xl font-bold group">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" class="h-6 w-6 sm:h-8 sm:w-8 flex-shrink-0">
            <defs>
              <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#3B82F6"/>
                <stop offset="100%" stop-color="#F59E0B"/>
              </linearGradient>
            </defs>
            <circle cx="24" cy="24" r="20" stroke="url(#logo-grad)" stroke-width="2.5" fill="none"/>
            <path d="M12 24h6l4-10 4 20 4-14 4 8h6" stroke="url(#logo-grad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <circle cx="24" cy="24" r="3" fill="#3B82F6"/>
          </svg>
          <span class="text-[#E8ECF4]"><span class="hidden sm:inline">Cerebrus </span><span class="gradient-text">Pulse</span></span>
        </a>
        <div class="flex items-center gap-3 sm:gap-6">
          <a href="#pricing" class="hidden sm:inline text-sm text-[#94A3B8] hover:text-[#E8ECF4] transition-colors duration-200">Pricing</a>
          <a href="#coins" class="hidden sm:inline text-sm text-[#94A3B8] hover:text-[#E8ECF4] transition-colors duration-200">Coins</a>
          <a href="/overview" class="btn-primary !px-3 !py-1.5 !text-xs sm:!px-5 sm:!py-2 sm:!text-sm !rounded-lg">
            Docs
          </a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>

    <!-- GSAP + ScrollTrigger CDN -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>

    <script is:inline>
      // Cerebrus Pulse — GSAP-Powered Parallax & Scroll-Reveal Engine
      (function () {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (prefersReducedMotion) {
          // Reduced motion: reveal everything immediately, no animations
          document.querySelectorAll('[data-reveal]').forEach((el) => el.classList.add('revealed'));
          return;
        }

        // ── Register GSAP Plugins ─────────────────────────────
        gsap.registerPlugin(ScrollTrigger);

        // ── Global GSAP defaults ──────────────────────────────
        gsap.defaults({
          ease: 'power3.out',
          duration: 0.9,
        });

        // ── PARALLAX: Hero layers via GSAP ScrollTrigger ──────
        const heroSection = document.querySelector('.landing-hero');
        if (heroSection) {
          // Brain parallax: slow drift + scale-down on scroll
          const brain = document.querySelector('[data-parallax="brain"]');
          if (brain) {
            gsap.to(brain, {
              y: 200,
              scale: 0.88,
              ease: 'none',
              scrollTrigger: {
                trigger: heroSection,
                start: 'top top',
                end: 'bottom top',
                scrub: 0.8,
              },
            });
          }

          // Hero text: push up + fade out
          const heroText = document.querySelector('[data-parallax="hero-text"]');
          if (heroText) {
            gsap.to(heroText, {
              y: -80,
              opacity: 0,
              ease: 'none',
              scrollTrigger: {
                trigger: heroSection,
                start: 'top top',
                end: '60% top',
                scrub: 0.5,
              },
            });
          }

          // Ambient orbs: slow parallax drift
          document.querySelectorAll('[data-parallax="slow"], [data-parallax="slower"], [data-parallax="medium"]').forEach((orb) => {
            const speed = { slow: 120, slower: 200, medium: 80 }[orb.dataset.parallax] || 120;
            gsap.to(orb, {
              y: speed,
              ease: 'none',
              scrollTrigger: {
                trigger: heroSection,
                start: 'top top',
                end: 'bottom top',
                scrub: 1,
              },
            });
          });
        }

        // ── SCROLL REVEALS: GSAP-powered with ScrollTrigger ──
        // slide-up reveals
        document.querySelectorAll('[data-reveal="slide-up"]').forEach((el) => {
          gsap.fromTo(el,
            { y: 50, opacity: 0 },
            {
              y: 0,
              opacity: 1,
              duration: 1,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 88%',
                end: 'top 60%',
                toggleActions: 'play none none none',
              },
              onComplete: () => el.classList.add('revealed'),
            }
          );
        });

        // stagger reveals: animate children within each parent grid
        const staggerParents = new Set();
        document.querySelectorAll('[data-reveal="stagger"]').forEach((el) => {
          if (el.parentElement) staggerParents.add(el.parentElement);
        });
        staggerParents.forEach((parent) => {
          const children = parent.querySelectorAll(':scope > [data-reveal="stagger"]');
          if (!children.length) return;

          gsap.fromTo(children,
            { y: 40, opacity: 0 },
            {
              y: 0,
              opacity: 1,
              duration: 0.8,
              stagger: 0.15,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: parent,
                start: 'top 85%',
                toggleActions: 'play none none none',
              },
              onComplete: function() {
                children.forEach(c => c.classList.add('revealed'));
              },
            }
          );
        });

        // wave reveals (coin chips)
        const waveParents = new Set();
        document.querySelectorAll('[data-reveal="wave"]').forEach((el) => {
          if (el.parentElement) waveParents.add(el.parentElement);
        });
        waveParents.forEach((parent) => {
          const children = parent.querySelectorAll(':scope > [data-reveal="wave"]');
          if (!children.length) return;

          gsap.fromTo(children,
            { y: 20, scale: 0.9, opacity: 0 },
            {
              y: 0,
              scale: 1,
              opacity: 1,
              duration: 0.5,
              stagger: 0.04,
              ease: 'back.out(1.7)',
              scrollTrigger: {
                trigger: parent,
                start: 'top 85%',
                toggleActions: 'play none none none',
              },
              onComplete: function() {
                children.forEach(c => c.classList.add('revealed'));
              },
            }
          );
        });

        // grow reveals (duality lines)
        document.querySelectorAll('[data-reveal="grow"]').forEach((el) => {
          gsap.fromTo(el,
            { scaleX: 0 },
            {
              scaleX: 1,
              duration: 1.2,
              ease: 'power2.inOut',
              scrollTrigger: {
                trigger: el,
                start: 'top 88%',
                toggleActions: 'play none none none',
              },
              onComplete: () => el.classList.add('revealed'),
            }
          );
        });

        // ── SECTION HEADING PARALLAX — subtle depth on section titles ──
        document.querySelectorAll('.landing-section h2, .landing-section-alt h2').forEach((h2) => {
          gsap.fromTo(h2,
            { y: 30 },
            {
              y: -15,
              ease: 'none',
              scrollTrigger: {
                trigger: h2,
                start: 'top 95%',
                end: 'top 20%',
                scrub: 0.6,
              },
            }
          );
        });

        // ── METRIC CARDS — counter animation ──────────────────
        document.querySelectorAll('.metric-card').forEach((card) => {
          gsap.fromTo(card,
            { y: 30, opacity: 0 },
            {
              y: 0,
              opacity: 1,
              duration: 0.7,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: card,
                start: 'top 90%',
                toggleActions: 'play none none none',
              },
            }
          );
        });

        // ── SECTION DIVIDERS — animated glow sweep ────────────
        document.querySelectorAll('.section-divider').forEach((divider) => {
          gsap.fromTo(divider,
            { opacity: 0, scaleX: 0 },
            {
              opacity: 1,
              scaleX: 1,
              duration: 1.4,
              ease: 'power2.inOut',
              scrollTrigger: {
                trigger: divider,
                start: 'top 92%',
                toggleActions: 'play none none none',
              },
            }
          );
        });

        // ── NAV: hide/show on scroll direction ────────────────
        const nav = document.querySelector('.nav-glass');
        if (nav) {
          let lastScrollY = 0;
          ScrollTrigger.create({
            start: 'top -80',
            end: 99999,
            onUpdate: (self) => {
              const scrollY = window.scrollY;
              if (scrollY > 80) {
                if (self.direction === 1) {
                  gsap.to(nav, { y: -100, duration: 0.3, ease: 'power2.in' });
                } else {
                  gsap.to(nav, { y: 0, duration: 0.3, ease: 'power2.out' });
                }
              } else {
                gsap.to(nav, { y: 0, duration: 0.3 });
              }
              lastScrollY = scrollY;
            },
          });
        }

        // ── CODE BLOCK — typing cursor blink effect ───────────
        const codeBlocks = document.querySelectorAll('.code-block-wrapper');
        codeBlocks.forEach((block) => {
          ScrollTrigger.create({
            trigger: block,
            start: 'top 80%',
            onEnter: () => block.classList.add('code-visible'),
          });
        });

      })();
    </script>
    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>
  </body>
</html>
