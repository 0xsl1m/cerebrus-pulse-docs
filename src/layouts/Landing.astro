---
import '../styles/landing.css';
import StructuredData from '../components/StructuredData.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalURL = 'https://pulse.openclaw.ai';
const ogImage = canonicalURL + '/images/og-image.jpg';
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- AI/LLM Discovery -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    <meta name="keywords" content="crypto API, cryptocurrency analysis, Hyperliquid, technical analysis, x402, micropayments, USDC, Base blockchain, ACP, Agent Commerce Protocol, Virtuals Protocol, RSI, EMA, Bollinger Bands, funding rates, market sentiment, AI agent, pay per query, no API key" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:site_name" content="Cerebrus Pulse" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <StructuredData
      title={title}
      description={description}
      url={canonicalURL}
    />
  </head>
  <body class="bg-[#0B0F1A] text-[#E8ECF4] antialiased">
    <nav class="nav-glass fixed top-0 z-50 w-full">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 sm:px-6 py-3 sm:py-4">
        <a href="/" class="flex items-center gap-2 sm:gap-3 text-base sm:text-xl font-bold group">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none" class="h-6 w-6 sm:h-8 sm:w-8 flex-shrink-0">
            <defs>
              <linearGradient id="logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#3B82F6"/>
                <stop offset="100%" stop-color="#F59E0B"/>
              </linearGradient>
            </defs>
            <circle cx="24" cy="24" r="20" stroke="url(#logo-grad)" stroke-width="2.5" fill="none"/>
            <path d="M12 24h6l4-10 4 20 4-14 4 8h6" stroke="url(#logo-grad)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <circle cx="24" cy="24" r="3" fill="#3B82F6"/>
          </svg>
          <span class="text-[#E8ECF4]"><span class="hidden sm:inline">Cerebrus </span><span class="gradient-text">Pulse</span></span>
        </a>
        <div class="flex items-center gap-3 sm:gap-6">
          <a href="#pricing" class="hidden sm:inline text-sm text-[#94A3B8] hover:text-[#E8ECF4] transition-colors duration-200">Pricing</a>
          <a href="#coins" class="hidden sm:inline text-sm text-[#94A3B8] hover:text-[#E8ECF4] transition-colors duration-200">Coins</a>
          <a href="/overview" class="btn-primary !px-3 !py-1.5 !text-xs sm:!px-5 sm:!py-2 sm:!text-sm !rounded-lg">
            Docs
          </a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>

    <script>
      // Cerebrus Pulse — Parallax & Scroll-Reveal Engine
      // Vanilla JS, no dependencies. ~90 lines.
      (function () {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // ── Reveal Animations (IntersectionObserver) ──────────────
        const revealEls = document.querySelectorAll('[data-reveal]');

        if (!prefersReducedMotion && revealEls.length) {
          // Group stagger siblings: assign incremental transition-delay
          // within each parent grid/flex container
          const staggerParents = new Set();
          revealEls.forEach((el) => {
            if (el.dataset.reveal === 'stagger' && el.parentElement) {
              staggerParents.add(el.parentElement);
            }
          });
          staggerParents.forEach((parent) => {
            const children = parent.querySelectorAll(':scope > [data-reveal="stagger"]');
            children.forEach((child, i) => {
              child.style.transitionDelay = `${i * 120}ms`;
            });
          });

          const revealObserver = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('revealed');
                  revealObserver.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
          );

          revealEls.forEach((el) => revealObserver.observe(el));
        } else {
          // Reduced motion: reveal everything immediately
          revealEls.forEach((el) => el.classList.add('revealed'));
        }

        // ── Parallax Depth (scroll-driven) ───────────────────────
        if (prefersReducedMotion) return;

        const parallaxEls = document.querySelectorAll('[data-parallax]');
        if (!parallaxEls.length) return;

        // Speed multipliers for each layer type
        const speeds = {
          brain: 0.3,        // brain moves slower (depth illusion)
          'hero-text': -0.15, // text moves slightly faster (negative = opposite)
          slow: 0.2,
          slower: 0.35,
          medium: 0.15,
        };

        let ticking = false;
        const heroSection = document.querySelector('.landing-hero');
        const heroHeight = heroSection ? heroSection.offsetHeight : 800;

        function onScroll() {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const scrollY = window.scrollY;

            parallaxEls.forEach((el) => {
              const type = el.dataset.parallax;
              const speed = speeds[type] || 0.2;
              const yOffset = scrollY * speed;

              if (type === 'brain') {
                // Brain: translate slower + scale down as user scrolls away
                const progress = Math.min(scrollY / heroHeight, 1);
                const scale = 1 - progress * 0.12; // scale to 0.88 at hero exit
                el.style.transform = `translateY(${yOffset}px) scale(${scale})`;
              } else if (type === 'hero-text') {
                // Hero text: slight upward push + fade out
                const progress = Math.min(scrollY / (heroHeight * 0.6), 1);
                const opacity = 1 - progress;
                el.style.transform = `translateY(${yOffset}px)`;
                el.style.opacity = opacity;
              } else {
                // Ambient orbs / CTA glow: simple vertical offset
                el.style.transform = `translateY(${yOffset}px)`;
              }
            });

            ticking = false;
          });
        }

        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll(); // initial position
      })();
    </script>
  </body>
</html>
